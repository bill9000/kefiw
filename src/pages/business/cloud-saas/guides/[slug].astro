---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { cloudSaasGuideHref, cloudSaasGuidePages } from '~/data/business-cloud-saas';

export function getStaticPaths() {
  return cloudSaasGuidePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={page.description} canonical={cloudSaasGuideHref(page)} keywords={page.keywords}>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/business/', label: 'Business' },
    { href: '/business/cloud-saas/', label: 'Cloud, SaaS, and AI' },
    { href: cloudSaasGuideHref(page), label: page.h1 },
  ]} />

  <article class="container-wide py-6">
    <header class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Cloud, SaaS, and AI guide</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      <p class="mt-3 text-lg font-semibold text-brand-800">{page.tagline}</p>
      <p class="mt-3 max-w-3xl text-slate-700">{page.promise}</p>
      {page.primaryCalculator && (
        <a href={page.primaryCalculator} class="mt-5 inline-flex rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800">Run the related calculator</a>
      )}
    </header>

    <section class="mt-8 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      {page.calculatorLinks.map((link) => (
        <a href={link.href} class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400 hover:shadow-sm">
          <p class="text-sm text-slate-700">{link.situation}</p>
          <p class="mt-2 text-sm font-semibold text-brand-800">{link.label}</p>
        </a>
      ))}
    </section>

    <section class="prose-tool mt-8 max-w-3xl">
      {page.sections.map((section) => (
        <>
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </>
      ))}
    </section>

    <section class="mt-8 max-w-4xl rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-950">
      <h2 class="text-lg font-semibold">Technology cost boundary</h2>
      <p class="mt-2">
        This guide is educational planning content. Cloud, SaaS, AI, licensing, and provider pricing can change by vendor,
        region, contract, support plan, renewal terms, usage pattern, and product architecture. Check provider pricing pages,
        current contracts, and usage data before relying on a scenario.
      </p>
      <p class="mt-2">
        Review the last complete billing period before changing a stack. Separate baseline subscriptions from usage-based
        spend, one-time migration work, support contracts, security requirements, and staff review time. The cheapest
        vendor on a calculator can still be expensive if switching creates operational drag.
      </p>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
