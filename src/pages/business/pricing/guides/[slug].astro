---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { pricingGuideHref, pricingGuidePages, type PricingContentPage } from '~/data/business-pricing';

export function getStaticPaths() {
  return pricingGuidePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: PricingContentPage;
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={page.description} canonical={pricingGuideHref(page)} keywords={page.keywords}>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }, { href: '/business/pricing/', label: 'Pricing' }, { href: pricingGuideHref(page), label: page.h1 }]} />

  <article class="container-narrow py-6">
    <header>
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Pricing guide</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      <p class="mt-3 text-lg font-semibold text-brand-800">{page.tagline}</p>
      <p class="mt-3 text-slate-700">{page.promise}</p>
      {page.primaryCalculator && (
        <a href={page.primaryCalculator} class="mt-5 inline-flex rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800">
          Run the calculator
        </a>
      )}
    </header>

    <div class="mt-8 space-y-6">
      {page.sections.map((section) => (
        <section class="rounded-lg border border-slate-200 bg-white p-5">
          <h2 class="text-xl font-bold text-slate-950">{section.heading}</h2>
          <p class="mt-2 whitespace-pre-line leading-7 text-slate-700">{section.body}</p>
          {section.bullets && section.bullets.length > 0 && (
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm leading-6 text-slate-700">
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
        </section>
      ))}
    </div>

    <section class="mt-8 rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-bold text-slate-950">A practical way to use this guide</h2>
      <div class="mt-3 space-y-4 leading-7 text-slate-700">
        <p>
          Start with one real offer, client, or pricing decision instead of a generic average. Write down the
          current price, the work included, the unpaid time around delivery, and the payment timing. Then run
          the linked calculator using conservative inputs. The goal is not to get a perfect number; it is to
          see which assumption has the most power over profit.
        </p>
        <p>
          The result can mislead you if the scope is vague, the client pays late, support work is not counted,
          or the price is being compared without taxes and owner pay. When the calculator exposes a weak
          price, the next step is usually to change scope, terms, or delivery rules before changing the headline
          price.
        </p>
      </div>
    </section>

    {page.calculatorLinks.length > 0 && (
      <section class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-5">
        <h2 class="text-xl font-bold text-slate-950">Use this next</h2>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          {page.calculatorLinks.map((link) => (
            <a href={link.href} class="rounded-md border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400">
              <p class="text-sm text-slate-700">{link.situation}</p>
              <p class="mt-2 text-sm font-semibold text-brand-800">{link.label}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
