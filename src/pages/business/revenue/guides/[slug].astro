---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { revenueGuideHref, revenueGuidePages } from '~/data/business-revenue';

export function getStaticPaths() {
  return revenueGuidePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={page.description} canonical={revenueGuideHref(page)} keywords={page.keywords}>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/business/', label: 'Business' },
    { href: '/business/revenue/', label: 'Revenue' },
    { href: revenueGuideHref(page), label: page.h1 },
  ]} />

  <article class="container-wide py-6">
    <header class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Revenue guide</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      <p class="mt-3 text-lg font-semibold text-brand-800">{page.tagline}</p>
      <p class="mt-3 max-w-3xl text-slate-700">{page.promise}</p>
      {page.primaryCalculator && (
        <a href={page.primaryCalculator} class="mt-5 inline-flex rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800">Run the related calculator</a>
      )}
    </header>

    <section class="mt-8 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      {page.calculatorLinks.map((link) => (
        <a href={link.href} class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400 hover:shadow-sm">
          <p class="text-sm text-slate-700">{link.situation}</p>
          <p class="mt-2 text-sm font-semibold text-brand-800">{link.label}</p>
        </a>
      ))}
    </section>

    <section class="prose-tool mt-8 max-w-3xl">
      {page.sections.map((section) => (
        <>
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </>
      ))}
    </section>

    <section class="mt-8 max-w-4xl rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-950">
      <h2 class="text-lg font-semibold">Revenue planning boundary</h2>
      <p class="mt-2">
        This guide is educational business-planning content. Revenue forecasts, churn estimates, sales targets, and cash
        runway scenarios depend on the inputs, customers, market, payment timing, and operating costs. Treat outputs as
        planning scenarios, not promises.
      </p>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
