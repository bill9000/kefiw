---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { businessSectionInventories, templateCategories } from '~/data/business-seo-moat';
---

<BaseLayout
  title="Business Templates and Scripts | Kefiw"
  description="Practical business scripts, worksheets, checklists, and decision memos for pricing, tax planning, hiring, revenue, and software spend."
  canonical="/business/templates/"
  keywords={['business templates', 'business scripts', 'small business worksheets', 'pricing email template', 'SaaS audit worksheet']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }, { href: '/business/templates/', label: 'Templates' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Business Templates</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Business Templates and Scripts</h1>
      <p class="mt-3 text-xl font-semibold text-brand-800">Turn calculator results into next steps.</p>
      <p class="mt-3 text-lg text-slate-700">
        Use practical scripts, worksheets, checklists, and decision memos for pricing, tax planning, hiring, revenue, and software spend.
      </p>
    </header>

    <section class="mb-10 grid gap-4 lg:grid-cols-4">
      {templateCategories.map((category) => (
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <h2 class="text-lg font-semibold text-slate-950">{category.category}</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {category.items.map((item) => (
              <li><a class="text-brand-700 hover:underline" href={item.href}>{item.title}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <div class="space-y-10">
      {businessSectionInventories.map((section) => (
        <section id={section.id} class="scroll-mt-36">
          <div class="mb-4 max-w-3xl">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{section.label}</p>
            <h2 class="text-2xl font-bold tracking-tight text-slate-950">{section.tagline}</h2>
          </div>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {section.templates.map((template) => (
              <a href={template.href} class="flex min-h-52 flex-col rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm">
                <h3 class="text-base font-semibold">{template.title}</h3>
                {template.tagline && <p class="mt-2 text-sm font-semibold text-brand-800">{template.tagline}</p>}
                {template.promise && <p class="mt-2 text-sm text-slate-700">{template.promise}</p>}
                {template.primaryCalculator && <p class="mt-auto pt-4 text-xs font-semibold uppercase tracking-wide text-slate-500">Use after calculator</p>}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="mt-10 rounded-lg border border-brand-200 bg-brand-50 p-5">
      <h2 class="text-xl font-semibold text-slate-950">Template rule</h2>
      <p class="mt-2 text-sm text-slate-700">
        Every high-value calculator result should lead to a next-action asset: a script, checklist, worksheet, or memo. The template should not replace the calculator. It should help the user act on the result.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a class="rounded-md bg-brand-700 px-3 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800" href="/business/guides/">Open guides</a>
        <a class="rounded-md border border-brand-200 bg-white px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400" href="/business/tracks/">Open Business Tracks</a>
      </div>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
