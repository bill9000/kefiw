---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { adviceLeavesOutSections } from '~/data/business-seo-moat';
---

<BaseLayout
  title="What Most Business Advice Leaves Out | Kefiw"
  description="The uncomfortable business assumptions most advice skips: pricing, hiring, tax, revenue, cloud, SaaS, and AI spend."
  canonical="/business/what-most-advice-leaves-out/"
  keywords={['what business advice leaves out', 'small business hidden costs', 'business decision traps', 'Kefiw business advice']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }, { href: '/business/what-most-advice-leaves-out/', label: 'What Advice Leaves Out' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Kefiw voice</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">What Most Business Advice Leaves Out</h1>
      <p class="mt-3 text-xl font-semibold text-brand-800">The uncomfortable part is usually where the decision gets better.</p>
      <p class="mt-3 text-lg text-slate-700">
        Kefiw is built around the hidden assumptions that make a business decision feel heavier than the headline number.
      </p>
    </header>

    <div class="grid gap-4 lg:grid-cols-2">
      {adviceLeavesOutSections.map((section) => (
        <section class="rounded-lg border border-slate-200 bg-white p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{section.section}</p>
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-slate-700">
            {section.ideas.map((idea) => <li>{idea}</li>)}
          </ul>
        </section>
      ))}
    </div>

    <section class="mt-10 rounded-lg border border-amber-200 bg-amber-50 p-5">
      <h2 class="text-xl font-semibold text-amber-950">Why this matters</h2>
      <p class="mt-2 text-sm text-amber-950">
        Most competitors can copy a formula. Fewer will say the useful thing: this hire may be owner overwhelm, this rate feels high because unpaid work is invisible, this S-corp savings number disappears when salary and admin rise, this AI tool saves time only if review time stays low, and this forecast is hope unless pipeline and cash timing support it.
      </p>
    </section>

    <section class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-slate-900">Use the index</h2>
      <div class="mt-4 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-md border border-slate-200 bg-white p-4 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/business/guides/">Read Business Guides</a>
        <a class="rounded-md border border-slate-200 bg-white p-4 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/business/templates/">Use Templates</a>
        <a class="rounded-md border border-slate-200 bg-white p-4 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/business/tracks/">Follow Business Tracks</a>
        <a class="rounded-md border border-slate-200 bg-white p-4 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/business/methodology/">Read Methodology</a>
      </div>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
