---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Business Lab — Tax, Pricing, Hiring, Revenue, and SaaS Calculators | Kefiw"
  description="Business calculators for self-employed tax planning, freelance rates, markup and margin, break-even math, hiring cost, revenue targets, and cloud/SaaS spend."
  canonical="/business/"
  keywords={['business calculators', 'self employed tax calculator', 'freelance rate calculator', 'markup margin calculator', 'break even calculator']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Business Lab</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Business</h1>
      <p class="mt-3 text-slate-700">
        A calculator-first vertical for self-employed operators, small businesses, consultants, and technical teams.
        Tax pages show assumptions plainly; pricing and hiring pages keep the math auditable and approved as educational business planning.
      </p>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      <section id="tax" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Tax</h2>
        <p class="mt-1 text-sm text-slate-600">Self-employed tax, quarterly estimates, S-Corp savings, LLC vs S-Corp, and reasonable salary.</p>
      </section>

      <section id="pricing" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Pricing</h2>
        <p class="mt-1 text-sm text-slate-600">Freelance rate, consultant rate, markup, margin, break-even, and profit calculators.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/calculators/minimum-viable-rate/">Minimum Viable / Freelance Rate</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/markup-margin-calculator/">Markup &amp; Margin</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/break-even-calculator/">Break-Even Calculator</a></li>
        </ul>
      </section>

      <section id="hiring" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Hiring</h2>
        <p class="mt-1 text-sm text-slate-600">Hiring cost, contractor vs employee, revenue per employee, payroll burden, and automation tradeoffs.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/calculators/hire-vs-automate/">Hire vs Automate</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/revenue-per-head/">Revenue per Employee</a></li>
        </ul>
      </section>

      <section id="revenue" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Revenue</h2>
        <p class="mt-1 text-sm text-slate-600">Revenue forecasts, sales targets, churn, subscription pricing, and operating leverage.</p>
      </section>

      <section id="cloud" class="rounded-lg border border-slate-200 bg-white p-4 md:col-span-2">
        <h2 class="text-lg font-semibold text-slate-900">Cloud &amp; SaaS</h2>
        <p class="mt-1 text-sm text-slate-600">SaaS cost, cloud cost, seat cost, and software ROI calculators.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/calculators/cloud-exit/">Cloud Exit</a></li>
          <li><a class="text-brand-700 hover:underline" href="/finance/crossover-calculator/">Subscription vs Lifetime Crossover</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/tech-debt-interest/">Software ROI / Tech Debt Interest</a></li>
        </ul>
      </section>
    </div>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
