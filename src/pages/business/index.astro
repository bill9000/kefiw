---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { VERTICAL_CALCULATORS_BY_AREA, verticalCalculatorHref, type VerticalCalculatorPage } from '~/data/vertical-calculators';

const businessPages = VERTICAL_CALCULATORS_BY_AREA.business;
const groupOrder = ['Tax', 'Pricing', 'Hiring', 'Revenue', 'Cloud'];
const groupCopy: Record<string, { tagline: string; promise: string; id: string }> = {
  Tax: {
    id: 'tax',
    tagline: 'Stop letting tax season be your business plan.',
    promise: 'Estimate tax reserves, quarterly payments, deduction caution, S-corp savings, and owner-salary assumptions before gross revenue starts looking spendable.',
  },
  Pricing: {
    id: 'pricing',
    tagline: 'Price the work so the work can survive.',
    promise: 'Turn rates, non-billable time, discounts, scope creep, client profitability, margin, and price increases into prices you can defend.',
  },
  Hiring: {
    id: 'hiring',
    tagline: 'Do not hire your way into a heavier business.',
    promise: 'Estimate payroll burden, contractor cost, automation tradeoffs, role clarity, revenue support, management load, and first-90-day risk before adding permanent overhead.',
  },
  Revenue: {
    id: 'revenue',
    tagline: 'Make revenue feel less imaginary.',
    promise: 'Forecast revenue, stress-test client loss, calculate sales targets, model churn, plan subscription pricing, and see whether growth actually improves cash and profit.',
  },
  Cloud: {
    id: 'cloud',
    tagline: 'Stop letting tools quietly become payroll.',
    promise: 'Estimate software subscriptions, seats, cloud usage, AI cost, renewals, tech debt, and cloud-exit tradeoffs before tool sprawl becomes permanent cost structure.',
  },
};

function pagesFor(group: string): VerticalCalculatorPage[] {
  return businessPages.filter((page) => page.group === group);
}
---

<BaseLayout
  title="Business Decision Calculators — Tax, Pricing, Hiring, Revenue, and SaaS | Kefiw"
  description="Business calculators for self-employed taxes, pricing, hiring, revenue forecasts, churn, SaaS costs, cloud costs, and software ROI."
  canonical="/business/"
  keywords={['business decision calculators', 'small business cost calculators', 'business what if calculator', 'small business planning calculators 2026']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Business</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Run the number before the number runs you.</h1>
      <p class="mt-3 text-lg text-slate-700">
        Kefiw helps operators test taxes, pricing, hiring, revenue, and software costs before the decision becomes expensive.
      </p>
      <p class="mt-2 max-w-3xl text-sm text-slate-600">
        This section is built around specific, anxious, threshold-based searches: is it worth it, what if income changes,
        can I afford this, where is the hidden cost, and when does the math stop working.
      </p>
    </header>

    <nav aria-label="Business calculator sections" class="mb-8 flex flex-wrap gap-2 text-sm">
      {groupOrder.map((group) => (
        <a href={`#${groupCopy[group].id}`} class="rounded-md border border-slate-200 bg-white px-3 py-2 font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-800">
          {group}
        </a>
      ))}
      <a href="/business/tracks/" class="rounded-md border border-brand-200 bg-brand-50 px-3 py-2 font-semibold text-brand-800 hover:border-brand-400 hover:bg-white">
        Business Tracks
      </a>
      <a href="/business/guides/" class="rounded-md border border-slate-200 bg-white px-3 py-2 font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-800">
        Guides
      </a>
      <a href="/business/templates/" class="rounded-md border border-slate-200 bg-white px-3 py-2 font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-800">
        Templates
      </a>
      <a href="/business/methodology/" class="rounded-md border border-slate-200 bg-white px-3 py-2 font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-800">
        Methodology
      </a>
    </nav>

    <section class="mb-10 grid gap-4 lg:grid-cols-2">
      <div class="rounded-lg border border-brand-200 bg-brand-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Guided journeys</p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-slate-950">Run the numbers in the right order</h2>
        <p class="mt-2 text-sm text-slate-700">
          Business Tracks turn calculators into decision paths for freelancing, pricing, hiring, tax reserves, S-corp decisions, revenue stress tests, and software spend cleanup.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href="/business/tracks/" class="rounded-md bg-brand-700 px-3 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800">Open Business Tracks</a>
          <a href="/tracks/start-freelancing/" class="rounded-md border border-brand-200 bg-white px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400">Start Freelancing</a>
          <a href="/tracks/hire-my-first-employee/" class="rounded-md border border-brand-200 bg-white px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400">Hire My First Employee</a>
        </div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Moat layer</p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-slate-950">Guides, templates, and trust rules</h2>
        <p class="mt-2 text-sm text-slate-700">
          The Business hub now has scenario guides, templates, a “what most advice leaves out” index, monetization policy, and publishing standards around the calculators.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href="/business/guides/" class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800 no-underline hover:border-brand-400">Business Guides</a>
          <a href="/business/templates/" class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800 no-underline hover:border-brand-400">Templates</a>
          <a href="/business/what-most-advice-leaves-out/" class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800 no-underline hover:border-brand-400">What advice leaves out</a>
          <a href="/business/how-kefiw-makes-money/" class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800 no-underline hover:border-brand-400">How Kefiw makes money</a>
          <a href="/business/tax/source-verification-policy/" class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800 no-underline hover:border-brand-400">Tax source policy</a>
        </div>
      </div>
    </section>

    <div class="space-y-10">
      {groupOrder.map((group) => (
        <section id={groupCopy[group].id} class="scroll-mt-32">
          <div class="mb-4 max-w-3xl">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{group}</p>
            <h2 class="mt-1 text-2xl font-bold tracking-tight text-slate-950">{groupCopy[group].tagline}</h2>
            <p class="mt-2 text-slate-700">{groupCopy[group].promise}</p>
            {group === 'Tax' && (
              <a href="/business/tax/" class="mt-3 inline-flex rounded-md border border-brand-200 bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400 hover:bg-white">
                Open the Tax decision hub
              </a>
            )}
            {group === 'Pricing' && (
              <a href="/business/pricing/" class="mt-3 inline-flex rounded-md border border-brand-200 bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400 hover:bg-white">
                Open the Pricing decision hub
              </a>
            )}
            {group === 'Hiring' && (
              <a href="/business/hiring/" class="mt-3 inline-flex rounded-md border border-brand-200 bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400 hover:bg-white">
                Open the Hiring decision hub
              </a>
            )}
            {group === 'Revenue' && (
              <a href="/business/revenue/" class="mt-3 inline-flex rounded-md border border-brand-200 bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400 hover:bg-white">
                Open the Revenue decision hub
              </a>
            )}
            {group === 'Cloud' && (
              <a href="/business/cloud-saas/" class="mt-3 inline-flex rounded-md border border-brand-200 bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400 hover:bg-white">
                Open the Cloud, SaaS, and AI decision hub
              </a>
            )}
          </div>

          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {pagesFor(group).map((page) => (
              <a href={verticalCalculatorHref(page)} class="flex min-h-64 flex-col rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm">
                <div class="text-sm font-bold text-slate-950">{page.h1}</div>
                {page.tagline && <div class="mt-2 text-sm font-semibold text-brand-800">{page.tagline}</div>}
                <p class="mt-2 text-sm text-slate-700">{page.promise ?? page.summary}</p>
                {page.bestFor && <p class="mt-3 text-xs text-slate-600"><span class="font-semibold text-slate-800">Best for:</span> {page.bestFor}</p>}
                {page.seoTargets && page.seoTargets.length > 0 && (
                  <div class="mt-3">
                    <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Search angles</div>
                    <ul class="mt-1 space-y-1 text-xs text-slate-600">
                      {page.seoTargets.slice(0, 3).map((target) => <li>{target}</li>)}
                    </ul>
                  </div>
                )}
                <span class="mt-auto pt-4 text-sm font-semibold text-brand-700">Run calculator</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="mt-10 max-w-4xl rounded-lg border border-slate-200 bg-slate-50 p-4">
      <h2 class="text-lg font-semibold text-slate-900">How to use this section</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
        <li>Run conservative, expected, and aggressive scenarios. One number is a guess; three numbers are a plan.</li>
        <li>Look for hidden costs: taxes, non-billable time, churn, unused seats, review work, payroll burden, and collection delay.</li>
        <li>Use the tool to ask better questions. Tax, legal, payroll, and compliance decisions still need the right professional when risk is material.</li>
      </ul>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
