---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import BusinessTemplateActionBlock from '~/components/business/BusinessTemplateActionBlock.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { hiringTemplateHref, hiringTemplatePages, type HiringContentPage } from '~/data/business-hiring';

export function getStaticPaths() {
  return hiringTemplatePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: HiringContentPage;
}

const { page } = Astro.props;
---

<BaseLayout title={page.title} description={page.description} canonical={hiringTemplateHref(page)} keywords={page.keywords}>
  <Breadcrumb
    crumbs={[
      { href: '/', label: 'Home' },
      { href: '/business/', label: 'Business' },
      { href: '/business/hiring/', label: 'Hiring' },
      { href: hiringTemplateHref(page), label: page.h1 },
    ]}
  />

  <article class="container-narrow py-6">
    <header>
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Hiring template</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      <p class="mt-3 text-lg text-slate-700">{page.tagline}</p>
      <p class="mt-3 text-slate-700">{page.promise}</p>
    </header>

    <section class="mt-8 grid gap-3 sm:grid-cols-2">
      {page.calculatorLinks.map((link) => (
        <a href={link.href} class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400 hover:shadow-sm">
          <p class="text-sm text-slate-700">{link.situation}</p>
          <p class="mt-2 text-sm font-semibold text-brand-800">{link.label}</p>
        </a>
      ))}
    </section>

    {page.sections.map((section) => (
      <section class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-5">
        <h2 class="text-xl font-bold text-slate-950">{section.heading}</h2>
        <p class="mt-2 whitespace-pre-line leading-7 text-slate-700">{section.body}</p>
        {section.bullets && (
          <ul class="mt-3 list-disc space-y-2 pl-5 text-slate-700">
            {section.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        )}
      </section>
    ))}

    <BusinessTemplateActionBlock sectionLabel="hiring" calculatorHref={page.calculatorLinks[0]?.href} />

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
