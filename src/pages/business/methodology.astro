---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import {
  measurementGroups,
  moatPageTypes,
  programmaticSeoGuardrails,
  publishingGate,
  rolloutPlan,
  seoOpportunityFactors,
  sourceReferences,
  structuredDataRules,
} from '~/data/business-seo-moat';
---

<BaseLayout
  title="Business Methodology, SEO Moat, and Publishing Standards | Kefiw"
  description="Kefiw's Business publishing methodology for calculator-led SEO pages, templates, monetization, internal links, structured data, and source discipline."
  canonical="/business/methodology/"
  keywords={['business methodology', 'Kefiw business methodology', 'business publishing standards', 'calculator SEO methodology', 'programmatic SEO guardrails']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }, { href: '/business/methodology/', label: 'Business Methodology' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Business methodology</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Business Methodology, SEO Moat, and Publishing Standards</h1>
      <p class="mt-3 text-xl font-semibold text-brand-800">Make the useful thing easier to find, easier to trust, and easier to act on.</p>
      <p class="mt-3 text-lg text-slate-700">
        Kefiw Business pages are built around calculator-led decisions, visible assumptions, source discipline, templates, internal tracks, and monetization that appears after value.
      </p>
    </header>

    <section class="mb-10 rounded-lg border border-brand-200 bg-brand-50 p-5">
      <h2 class="text-xl font-semibold text-slate-950">SEO moat strategy</h2>
      <p class="mt-2 text-sm text-slate-700">
        Kefiw does not aim to publish thin pages for every keyword. The target is decision-modified long-tail searches where the user has stress, urgency, a hidden cost, or a threshold decision.
      </p>
      <p class="mt-3 text-sm text-slate-700">
        Examples include: freelance rate if I only bill 20 hours, is S-corp worth it after payroll costs, what if one big client leaves, AI saves time but adds review work, busy but not profitable small business, and cloud bill shock calculator.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold tracking-tight text-slate-950">Nine moat page types</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {moatPageTypes.map((item) => (
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h3 class="text-base font-semibold text-slate-950">{item.type}</h3>
            <p class="mt-2 text-sm text-slate-700">{item.purpose}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Kefiw SEO Opportunity Score</h2>
      <p class="mt-2 text-sm text-slate-700">Every potential Business page should score 1 to 5 on these factors before it is built.</p>
      <div class="mt-4 grid gap-3 md:grid-cols-2">
        {seoOpportunityFactors.map((factor) => (
          <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
            <h3 class="text-sm font-semibold text-slate-950">{factor.factor}</h3>
            <p class="mt-1 text-sm text-slate-700">{factor.question}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10 grid gap-6 lg:grid-cols-2">
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-semibold text-slate-900">Internal linking rules</h2>
        <p class="mt-2 text-sm text-slate-700">Every Business page should link in four directions:</p>
        <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
          <li>Up to the section hub.</li>
          <li>Across to related calculators.</li>
          <li>Down to templates.</li>
          <li>Forward to a Business Track.</li>
        </ul>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-semibold text-slate-900">Indexation rules</h2>
        <p class="mt-2 text-sm text-slate-700">Index calculators, strong guides, templates, tracks, methodology pages, scorecards, and strong scenarios. Noindex thin result-only pages, saved states, query-parameter variants, incomplete templates, and duplicate tag pages.</p>
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Structured data rules</h2>
      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
        {structuredDataRules.map((rule) => <li>{rule}</li>)}
      </ul>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Programmatic SEO guardrails</h2>
      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
        {programmaticSeoGuardrails.map((rule) => <li>{rule}</li>)}
      </ul>
    </section>

    <section class="mb-10 rounded-lg border border-emerald-200 bg-emerald-50 p-5">
      <h2 class="text-xl font-semibold text-emerald-950">Business publishing gate</h2>
      <div class="mt-4 grid gap-2 md:grid-cols-2">
        {publishingGate.map((item) => (
          <div class="rounded-md bg-white p-3 text-sm text-slate-700">[ ] {item}</div>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold tracking-tight text-slate-950">Measurement system</h2>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        {measurementGroups.map((group) => (
          <div class="rounded-lg border border-slate-200 bg-white p-5">
            <h3 class="text-lg font-semibold text-slate-950">{group.group}</h3>
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
              {group.metrics.map((metric) => <li>{metric}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-slate-900">90-day rollout plan</h2>
      <div class="mt-4 space-y-4">
        {rolloutPlan.map((phase) => (
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h3 class="text-base font-semibold text-slate-950">{phase.phase}</h3>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
              {phase.work.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Source references</h2>
      <p class="mt-2 text-sm text-slate-700">
        Business methodology pages are source-checked when they discuss search guidance, monetization/disclosure rules, structured data, or high-risk tax/payroll/cloud assumptions.
      </p>
      <div class="mt-4 rounded-md border border-amber-200 bg-amber-50 p-3 text-sm text-amber-950">
        Tax calculators have a dedicated source-verification policy because tax reserves, deductions, S-corp planning, and quarterly-payment scenarios need more visible source discipline.
        <a class="font-semibold text-amber-950 underline" href="/business/tax/source-verification-policy/">Open the Tax Source Verification Policy</a>.
      </div>
      <ul class="mt-3 space-y-2 text-sm">
        {sourceReferences.map((source) => (
          <li><a class="text-brand-700 hover:underline" href={source.href}>{source.label}</a></li>
        ))}
      </ul>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
