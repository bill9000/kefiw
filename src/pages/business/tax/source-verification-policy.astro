---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { VERTICAL_CALCULATORS_BY_AREA } from '~/data/vertical-calculators';

const taxCalculators = VERTICAL_CALCULATORS_BY_AREA.business.filter((page) => page.group === 'Tax');

const sourcePackRules = [
  {
    heading: 'Self-employment and estimated tax tools',
    checks: [
      'IRS self-employment tax framing and Form 1040-ES planning references',
      'Social Security wage base and Medicare assumptions',
      'Payment-period, safe-harbor, withholding, and uneven-income caveats',
      'Federal-only default unless a state reserve assumption is entered',
    ],
  },
  {
    heading: 'Deduction and documentation tools',
    checks: [
      'IRS business-expense resource guidance instead of stale Publication 535-only citations',
      'Schedule C, mileage, home-office, documentation, mixed-use, and capitalization prompts',
      'Explicit wording that the tool flags caution issues and does not approve deductions',
    ],
  },
  {
    heading: 'S-corp and reasonable salary tools',
    checks: [
      'IRS reasonable-compensation and officer wage treatment guidance',
      'Payroll, filing, bookkeeping, state/entity, and admin-cost placeholders',
      'Explicit wording that the tool does not determine reasonable salary or tax election status',
    ],
  },
];

const wordingRules = [
  'Call outputs estimates, planning scenarios, reserve targets, or model results.',
  'Do not call a calculator result a tax bill, filing position, guaranteed penalty result, or professional determination.',
  'Show assumptions that can move the result: wage base, income timing, withholding, payments, salary, payroll cost, filing cost, records, and state assumptions.',
  'Make "what this tool does not do" visible on high-risk tax calculators.',
  'Use the current source-check date on Tax calculators: April 30, 2026.',
];
---

<BaseLayout
  title="Tax Source Verification Policy | Kefiw"
  description="How Kefiw source-checks tax calculators, deduction tools, S-corp planning pages, and educational tax assumptions."
  canonical="/business/tax/source-verification-policy/"
  keywords={['tax source verification policy', 'Kefiw tax sources', 'tax calculator source checks', 'self-employed tax source policy']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/business/', label: 'Business' }, { href: '/business/tax/', label: 'Tax' }, { href: '/business/tax/source-verification-policy/', label: 'Source Verification' }]} />

  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Tax source policy</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Tax Source Verification Policy</h1>
      <p class="mt-3 text-xl font-semibold text-brand-800">Visible assumptions before tax math.</p>
      <p class="mt-3 text-lg text-slate-700">
        Kefiw tax tools are educational planning calculators. They should help operators ask better questions, protect cash, and audit assumptions without pretending a calculator is a tax filing position.
      </p>
    </header>

    <section class="mb-10 rounded-lg border border-amber-200 bg-amber-50 p-5">
      <h2 class="text-xl font-semibold text-amber-950">Required Tax footer</h2>
      <p class="mt-2 text-sm leading-6 text-amber-950">
        Last source check: April 30, 2026. Tax rules, thresholds, forms, deadlines, and state rules can change. Kefiw shows the assumptions used so you can audit the math before relying on the result. Tax calculators do not provide legal, tax, accounting, payroll, or filing advice.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold tracking-tight text-slate-950">What gets source checked</h2>
      <div class="mt-4 grid gap-4 lg:grid-cols-3">
        {sourcePackRules.map((pack) => (
          <div class="rounded-lg border border-slate-200 bg-white p-5">
            <h3 class="text-lg font-semibold text-slate-950">{pack.heading}</h3>
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
              {pack.checks.map((check) => <li>{check}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Wording rules</h2>
      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
        {wordingRules.map((rule) => <li>{rule}</li>)}
      </ul>
    </section>

    <section class="mb-10">
      <div class="mb-4 max-w-4xl">
        <h2 class="text-2xl font-bold tracking-tight text-slate-950">Current tax calculator source packs</h2>
        <p class="mt-2 text-sm text-slate-700">
          Each high-risk tax tool carries a source scope, assumptions, visible caveats, and links to source families used by the calculator.
        </p>
      </div>
      <div class="grid gap-4 lg:grid-cols-2">
        {taxCalculators.map((page) => (
          <div class="rounded-lg border border-slate-200 bg-white p-5">
            <h3 class="text-lg font-semibold text-slate-950">{page.h1}</h3>
            {page.sourceCheckedAt && <p class="mt-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Last source check: {page.sourceCheckedAt}</p>}
            {page.sourceScope && <p class="mt-2 text-sm leading-6 text-slate-700">{page.sourceScope}</p>}
            {page.assumptions && page.assumptions.length > 0 && (
              <div class="mt-3">
                <h4 class="text-sm font-semibold text-slate-900">Assumptions shown</h4>
                <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-slate-700">
                  {page.assumptions.map((assumption) => <li>{assumption}</li>)}
                </ul>
              </div>
            )}
            {page.sources && page.sources.length > 0 && (
              <div class="mt-3">
                <h4 class="text-sm font-semibold text-slate-900">Source links</h4>
                <ul class="mt-1 space-y-1 text-sm">
                  {page.sources.map((source) => (
                    <li><a class="text-brand-700 hover:underline" href={source.href}>{source.label}</a></li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-lg border border-brand-200 bg-brand-50 p-5">
      <h2 class="text-xl font-semibold text-slate-950">Update rhythm</h2>
      <p class="mt-2 text-sm leading-6 text-slate-700">
        Tax source checks should be refreshed when IRS or SSA thresholds change, forms are revised, due-date guidance changes, deduction documentation guidance changes, S-corp compensation guidance changes, or a calculator adds a new tax assumption.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a class="rounded-md bg-brand-700 px-3 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800" href="/business/tax/">Open Tax hub</a>
        <a class="rounded-md border border-brand-200 bg-white px-3 py-2 text-sm font-semibold text-brand-800 no-underline hover:border-brand-400" href="/business/methodology/">Business methodology</a>
      </div>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
