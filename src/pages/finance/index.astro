---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ToolCard from '~/components/ToolCard.astro';
import { TOOLS_BY_ID, type ToolConfig } from '~/data/tools';
import { DECISION_CLUSTERS } from '~/data/decision-clusters';

interface Pillar {
  roman: string;
  title: string;
  tagline: string;
  blurb: string;
  tools: ToolConfig[];
}

const rawPillars: Array<{ roman: string; title: string; tagline: string; blurb: string; toolIds: string[] }> = [
  {
    roman: 'I',
    title: 'Strategic Capital',
    tagline: 'The VC / Owner Suite',
    blurb: 'High-level management of entities, investments, and long-term equity. Runway, break-even year, opportunity cost, and the salary-replacement line.',
    toolIds: [
      'runway-zero',
      'shock-survival',
      'horizon-point',
      'sp500-check',
      'leap-date',
      'break-even-calculator',
      'minimum-viable-rate',
      'savings-goal-calculator',
      'mortgage-calculator',
      'mortgage-extra-payment-calculator',
    ],
  },
  {
    roman: 'II',
    title: 'Operational Scaling',
    tagline: 'The Builder Suite',
    blurb: 'Efficiency of labor, infrastructure, and technical debt. Subscription vs lifetime, self-host vs managed, hire vs automate, DIY vs outsource.',
    toolIds: [
      'crossover-calculator',
      'cloud-exit',
      'hire-vs-automate',
      'tech-debt-interest',
      'value-floor',
      'revenue-per-head',
      'markup-margin-calculator',
      'markup-calculator',
      'margin-calculator',
    ],
  },
  {
    roman: 'III',
    title: 'Scarcity Triage',
    tagline: 'The Survival Suite',
    blurb: 'Hard-mode reality of short cash, unemployment, and crisis. Calorie-per-dollar, bill priority, payday-loan APR, boots theory, and time poverty.',
    toolIds: [
      'bio-fuel',
      'bill-triage',
      'gig-net-floor',
      'vimes-utility',
      'trap-detector',
      'time-poverty',
      'calorie-optimizer',
      'default-optimizer',
      'liquid-value',
      'asset-liquidator',
    ],
  },
  {
    roman: 'IV',
    title: 'Biological Maintenance',
    tagline: 'The Human Suite',
    blurb: 'Human-capital cost of health, social, and mental state. Social-connection energy tax, sleep vs cognition, rent-alone premium, dopamine triage.',
    toolIds: [
      'social-latency',
      'dopamine-minimum',
      'stability-coefficient',
      'burnout-monitor',
      'time-to-human',
      'vice-to-value',
    ],
  },
];

const pillars: Pillar[] = rawPillars
  .map((p) => ({
    roman: p.roman,
    title: p.title,
    tagline: p.tagline,
    blurb: p.blurb,
    tools: p.toolIds
      .map((id) => TOOLS_BY_ID[id])
      .filter((t): t is ToolConfig => !!t && !t.comingSoon),
  }))
  .filter((p) => p.tools.length > 0);

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/finance/', label: 'Finance' },
];
---
<BaseLayout
  title="Finance — Capital Corridor | Kefiw"
  description="Deterministic financial intelligence: runway, growth/burn horizons, crisis resilience, and lifetime crossovers. Four industrial pillars, closed-form math, no AI, no probabilistic guesses."
  canonical="/finance/"
  keywords={['finance calculators', 'capital corridor', 'runway calculator', 'break-even calculator', 'burn rate', 'shock survival', 'crossover calculator']}
>
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Capital Corridor</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Finance</h1>
      <p class="mt-3 text-lg text-slate-700">
        A deterministic toolkit for high-stakes capital logic, sorted into four industrial pillars.
      </p>
      <p class="mt-2 text-slate-600">
        Every result is a closed-form formula or bounded simulation you can verify by hand.
        No AI layer, no probabilistic guesses — same inputs, same outputs, every time.
      </p>
    </header>

    <section class="mb-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">What it is</div>
        <p class="mt-1 text-sm text-slate-600">
          Calculators that answer yes/no and when questions — not rough estimates.
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">How it works</div>
        <p class="mt-1 text-sm text-slate-600">
          Math is explicit: contribution margins, amortization, compound growth. Every number is traceable.
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">Why it matters</div>
        <p class="mt-1 text-sm text-slate-600">
          Capital decisions deserve reproducible results — not an opaque answer you can't audit.
        </p>
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-emerald-200 bg-emerald-50 p-5">
      <h2 class="text-lg font-semibold text-emerald-900">Curated decision clusters</h2>
      <p class="mt-1 text-sm text-emerald-900/80">
        Four SEO-anchored guide bundles that cross-link the tools most often used together.
      </p>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {DECISION_CLUSTERS.map((c) => (
          <li>
            <a
              href={`/finance/clusters/${c.slug}/`}
              class="block rounded-md border border-emerald-200 bg-white p-3 hover:border-emerald-500 hover:bg-emerald-50"
            >
              <div class="text-xs font-semibold uppercase tracking-wide text-emerald-700">
                Cluster {c.letter} — {c.pillar}
              </div>
              <div class="mt-1 text-sm font-semibold text-slate-900">{c.h1}</div>
              <div class="mt-0.5 text-xs text-slate-600">{c.subhead}</div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {pillars.map((p) => (
      <section class="mb-10">
        <div class="flex items-baseline gap-3">
          <span class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Pillar {p.roman}</span>
          <h2 class="text-xl font-semibold">{p.title}</h2>
          <span class="text-xs text-slate-500">— {p.tagline}</span>
        </div>
        <p class="mt-1 max-w-3xl text-sm text-slate-600">{p.blurb}</p>
        <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {p.tools.map((t) => <ToolCard tool={t} />)}
        </div>
        {p.roman === 'IV' && (
          <div class="mt-4 rounded-lg border border-cyan-200 bg-cyan-50 p-4">
            <div class="text-sm font-semibold text-cyan-900">Extended biological suite</div>
            <p class="mt-1 text-sm text-cyan-900/80">
              The human-capital tools above handle the decision layer — social ROI, stability cost, burnout math.
              For the deterministic biology underneath (BMR, BAC, 1RM, WBGT, WHtR, protein bolus, CO₂ cognitive tax),
              see the full <a href="/health/" class="font-semibold underline hover:text-cyan-700">Health suite</a> — 20 instruments across 5 sub-systems.
            </p>
          </div>
        )}
      </section>
    ))}

    <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-lg font-semibold text-slate-900">About the Finance suite</h2>
      <p class="mt-2 text-sm text-slate-700">
        Four industrial pillars map to four capital horizons: Strategic Capital (runway, equity, salary replacement),
        Operational Scaling (infrastructure, technical debt, build-vs-buy), Scarcity Triage (cash-short survival math),
        and Biological Maintenance (human-capital costs that don't show up on the bank statement).
        Each tool is a closed-form formula or bounded simulation — inputs persist locally in your browser, nothing is sent to a server.
      </p>
    </section>
  </article>
</BaseLayout>
