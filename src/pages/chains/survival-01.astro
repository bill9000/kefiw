---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import PipelineStage from '~/components/pipeline/PipelineStage.astro';
import PipelineConnector from '~/components/pipeline/PipelineConnector.tsx';
import PipelineReset from '~/components/pipeline/PipelineReset.tsx';
import SubPurge from '~/components/tools/SubPurge.tsx';
import GigNetFloor from '~/components/tools/GigNetFloor.tsx';
import RunwayZero from '~/components/tools/RunwayZero.tsx';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/chains/', label: 'Chains' },
  { href: '/chains/survival-01/', label: 'SURVIVAL-01' },
];

const moneyFmt = (n: number) =>
  n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
---
<BaseLayout
  title="SURVIVAL-01 — The Life-Path Pipeline | Kefiw"
  description="Three calculators, one session context. Find hidden subscription leaks, size a real side-hustle, and watch your bankruptcy date move. Deterministic, chained, live."
  canonical="/chains/survival-01/"
  keywords={['life path calculator', 'financial survival pipeline', 'subscription purge runway', 'chained calculators', 'deterministic engine']}
>
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600">
        Chain · SURVIVAL-01
      </p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">
        The Life-Path Pipeline
      </h1>
      <p class="mt-3 text-lg text-slate-700">
        Three calculators, one session. Find the hidden leaks, size a realistic side-hustle, and watch
        your bankruptcy date move in real time. The same deterministic math — connected.
      </p>
      <p class="mt-2 text-sm text-slate-600">
        Each stage's output is a <span class="font-mono text-cyan-600">Live Variable</span> that feeds
        the next. No AI layer, no stochastic guesses — just closed-form formulas wired together.
      </p>
    </header>

    <section class="mb-6 rounded-lg border border-slate-200 bg-slate-50 p-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500">
            How the pipeline works
          </div>
          <p class="mt-1 max-w-2xl text-sm text-slate-600">
            Edit any stage. The output chip below it writes to the shared session context. The next
            stage reads those chips on mount and re-hydrates. Reset clears the context (your per-tool
            inputs are preserved).
          </p>
        </div>
        <PipelineReset client:load />
      </div>
    </section>

    <PipelineStage
      stage={1}
      totalStages={3}
      title="Find $50+ in hidden subscription leaks"
      summary="List every recurring charge. The sum becomes your Recoverable Cash — piped downstream as the first live variable."
      toolHref="/logic/leak-detection/"
      toolTitle="Subscription Purge"
    >
      <SubPurge client:load />
    </PipelineStage>

    <PipelineConnector
      client:load
      fieldKey="monthly_savings_recoverable"
      label="monthly savings recoverable"
      format={moneyFmt}
    />

    <PipelineStage
      stage={2}
      totalStages={3}
      title="Size a real side-hustle after gas and depreciation"
      summary="Gross pay minus IRS-standard operating cost, scaled by shifts per week. Monthly Net feeds stage three."
      toolHref="/decisions/gig-net-floor/"
      toolTitle="Gig-Net Floor"
    >
      <GigNetFloor client:load />
    </PipelineStage>

    <PipelineConnector
      client:load
      fieldKey="side_hustle_monthly_net"
      label="side hustle monthly net"
      format={moneyFmt}
    />

    <PipelineStage
      stage={3}
      totalStages={3}
      title="See the Zero Date move"
      summary="Cash ÷ (burn − effective revenue). Live Variables stack into Effective Monthly Revenue. Watch the ZERO marker slide right as you tune upstream."
      toolHref="/decisions/runway-zero/"
      toolTitle="Runway Zero"
    >
      <RunwayZero client:load />
    </PipelineStage>

    <section class="mx-auto mt-10 max-w-4xl rounded-lg border border-cyan-200 bg-cyan-50 p-5">
      <h2 class="text-lg font-semibold text-cyan-900">Why this pipeline exists</h2>
      <p class="mt-2 text-sm text-cyan-900/90">
        A single number is rarely the answer. Knowing you waste $60/mo on subscriptions is one fact.
        Knowing that cutting that stack extends your bankruptcy date by <em>three weeks</em> is a
        decision. The pipeline is the connective tissue between the two.
      </p>
      <p class="mt-2 text-sm text-cyan-900/90">
        Same session context, same deterministic math. Change any input at any stage — every
        downstream readout updates live. Nothing is stored off-device.
      </p>
    </section>

    <section class="mx-auto mt-6 max-w-4xl rounded-lg border border-slate-200 bg-white p-5">
      <div class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500">Next chains</div>
      <p class="mt-1 text-sm text-slate-600">
        The pipeline primitive is live. Future chains compose the same context:
      </p>
      <ul class="mt-3 grid gap-2 text-sm text-slate-700 sm:grid-cols-2">
        <li class="rounded border border-slate-200 p-3">
          <strong>PIVOT-02 · Entrepreneurial Transition</strong>
          <p class="mt-1 text-xs text-slate-500">Minimum Viable Rate → Break-Even Calculator → Runway Zero</p>
        </li>
        <li class="rounded border border-slate-200 p-3">
          <strong>MOVE-03 · Geographic Relocation</strong>
          <p class="mt-1 text-xs text-slate-500">Geo Arbitrage → Subscription Purge → Runway Zero</p>
        </li>
        <li class="rounded border border-slate-200 p-3">
          <strong>FOCUS-04 · Cognitive Repair Day</strong>
          <p class="mt-1 text-xs text-slate-500">Task Switching Tax → Focus Horizon → Decision Fatigue</p>
        </li>
        <li class="rounded border border-slate-200 p-3">
          <strong>STRESS-05 · The Triad</strong>
          <p class="mt-1 text-xs text-slate-500">Same pipeline primitive, rendered as three parallel scenarios.</p>
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>
