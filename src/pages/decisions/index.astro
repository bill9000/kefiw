---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ToolCard from '~/components/ToolCard.astro';
import { TOOLS_BY_ID, type ToolConfig } from '~/data/tools';

interface Pillar {
  title: string;
  blurb: string;
  tools: ToolConfig[];
}

const rawPillars: Array<{ title: string; blurb: string; toolIds: string[] }> = [
  {
    title: 'Break-even points',
    blurb: 'When does a purchase, project, or product start paying for itself? Find the exact crossover.',
    toolIds: ['break-even-calculator', 'mortgage-extra-payment-calculator'],
  },
  {
    title: 'Tradeoffs',
    blurb: 'Compare scenarios side-by-side — more rate vs shorter term, bigger contribution vs longer horizon.',
    toolIds: ['mortgage-calculator', 'markup-calculator', 'margin-calculator'],
  },
  {
    title: 'Runway to a goal',
    blurb: 'How long until the target is hit at the current pace — and what shortens the path.',
    toolIds: ['savings-goal-calculator'],
  },
];

const pillars: Pillar[] = rawPillars
  .map((p) => ({
    title: p.title,
    blurb: p.blurb,
    tools: p.toolIds
      .map((id) => TOOLS_BY_ID[id])
      .filter((t): t is ToolConfig => !!t && !t.comingSoon),
  }))
  .filter((p) => p.tools.length > 0);

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/decisions/', label: 'Decisions' },
];
---
<BaseLayout
  title="Decisions — Deterministic Tools for Tradeoffs, Runway & Break-even | Kefiw"
  description="Deterministic calculators that model tradeoffs, runway, break-even points, and survival windows. No AI, just math — inputs map to outputs, every time."
  canonical="/decisions/"
  keywords={['decision calculators', 'break-even calculator', 'tradeoff tools', 'runway calculator', 'deterministic']}
>
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">New section</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Decisions</h1>
      <p class="mt-3 text-lg text-slate-700">
        Deterministic tools that model tradeoffs, runway, break-even points, and survival windows.
      </p>
      <p class="mt-2 text-slate-600">
        Every result comes from a closed-form formula or a bounded simulation you can verify by hand.
        No AI layer, no probabilistic guesses — same inputs, same outputs, every time. Designed for the
        moment you need to decide and show your work.
      </p>
    </header>

    <section class="mb-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">What it is</div>
        <p class="mt-1 text-sm text-slate-600">
          Calculators that answer yes/no and when questions — not rough estimates.
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">How it works</div>
        <p class="mt-1 text-sm text-slate-600">
          Math is explicit: contribution margins, amortization, compound growth. Every number is
          traceable.
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="text-sm font-semibold text-slate-900">Why it matters</div>
        <p class="mt-1 text-sm text-slate-600">
          Decisions deserve reproducible results — not an opaque answer you can't audit.
        </p>
      </div>
    </section>

    {pillars.map((p) => (
      <section class="mb-8">
        <h2 class="text-xl font-semibold">{p.title}</h2>
        <p class="mt-1 max-w-3xl text-sm text-slate-600">{p.blurb}</p>
        <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {p.tools.map((t) => <ToolCard tool={t} />)}
        </div>
      </section>
    ))}

    <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-lg font-semibold text-slate-900">Coming to Decisions</h2>
      <ul class="mt-2 list-disc pl-6 text-sm text-slate-700">
        <li>Cash runway — months of operation at current burn</li>
        <li>Loan survival window — how long savings last under an unexpected expense</li>
        <li>Buy-vs-rent break-even horizon</li>
        <li>Subscription cost crossover vs one-time purchase</li>
      </ul>
    </section>
  </article>
</BaseLayout>
