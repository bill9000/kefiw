---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import {
  PROPERTY_CHECKLISTS,
  propertyChecklistHref,
  type PropertyChecklist,
} from '~/data/property-checklists';

export function getStaticPaths() {
  return PROPERTY_CHECKLISTS.map((checklist) => ({
    params: { slug: checklist.slug },
    props: { checklist },
  }));
}

interface Props {
  checklist: PropertyChecklist;
}

const { checklist } = Astro.props;
const canonical = propertyChecklistHref(checklist);
---

<BaseLayout
  title={checklist.title}
  description={checklist.description}
  canonical={canonical}
  keywords={checklist.keywords}
  ogType="article"
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/property/', label: 'Property' },
    { href: '/property/checklists/', label: 'Checklists' },
    { href: canonical, label: checklist.h1 },
  ]} />

  <article class="container-wide py-6">
    <header class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Checklist</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{checklist.h1}</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">{checklist.description}</p>
      <p class="mt-3 max-w-3xl rounded-md border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm leading-6 text-cyan-950">
        <span class="font-semibold">Best for:</span> {checklist.bestFor}
      </p>
      <p class="mt-3 max-w-3xl rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm leading-6 text-slate-700">
        <span class="font-semibold">Use when:</span> {checklist.trigger}
      </p>
      {checklist.warning && (
        <p class="mt-3 max-w-3xl rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm leading-6 text-amber-950">
          {checklist.warning}
        </p>
      )}
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800" href="/property/decision-packet/">Build decision packet</a>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/">All checklists</a>
      </div>
    </header>

    <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="space-y-8">
        {checklist.sections.map((section) => (
          <section class="rounded-lg border border-slate-200 bg-white p-4">
            <h2 class="text-xl font-semibold text-slate-900">{section.title}</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">{section.why}</p>
            <div class="mt-4 grid gap-3">
              {section.items.map((item) => (
                <section class={`rounded-md border p-3 ${item.warning ? 'border-amber-200 bg-amber-50' : item.required ? 'border-brand-200 bg-brand-50' : 'border-slate-200 bg-slate-50'}`}>
                  <div class="flex flex-wrap items-start justify-between gap-2">
                    <h3 class="text-sm font-semibold text-slate-900">{item.label}</h3>
                    {item.required && <span class="rounded bg-brand-700 px-2 py-1 text-[11px] font-semibold uppercase tracking-wide text-white">Core</span>}
                  </div>
                  <p class="mt-1 text-sm leading-6 text-slate-700">{item.detail}</p>
                  {item.warning && <p class="mt-2 text-xs font-semibold leading-5 text-amber-950">{item.warning}</p>}
                </section>
              ))}
            </div>
          </section>
        ))}

        <section class="rounded-lg border border-cyan-200 bg-cyan-50 p-4">
          <h2 class="text-lg font-semibold text-cyan-950">Before you act</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-sm leading-6 text-cyan-950">
            {checklist.beforeYouAct.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="rounded-lg border border-brand-200 bg-brand-50 p-4">
          <h2 class="text-lg font-semibold text-slate-950">Decision packet prompt</h2>
          <p class="mt-2 text-sm leading-6 text-slate-700">{checklist.packetPrompt}</p>
          <a class="mt-3 inline-block text-sm font-semibold text-brand-700 hover:underline" href="/property/decision-packet/">Open the decision packet</a>
        </section>
      </div>

      <aside class="h-fit rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Use next</h2>
        <div class="mt-3 grid gap-2">
          {checklist.relatedLinks.map((item) => (
            <a class="rounded-md border border-slate-200 bg-slate-50 p-2 text-xs font-semibold text-brand-700 no-underline hover:border-brand-400" href={item.href}>
              {item.label}
              {item.note && <span class="mt-1 block font-normal text-slate-600">{item.note}</span>}
            </a>
          ))}
        </div>
        <section class="mt-4 border-t border-slate-200 pt-4">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">More checklists</h2>
          <nav class="mt-3 space-y-1 text-sm">
            {PROPERTY_CHECKLISTS.map((item) => (
              <a
                href={propertyChecklistHref(item)}
                class={`block rounded-md px-3 py-2 no-underline ${item.slug === checklist.slug ? 'bg-brand-50 font-semibold text-brand-800' : 'text-slate-700 hover:bg-slate-50'}`}
              >
                {item.h1}
              </a>
            ))}
          </nav>
        </section>
      </aside>
    </div>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
