---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import PropertyComparisonWorkbench from '~/components/property/PropertyComparisonWorkbench';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Contractor Quote Comparison Matrix | Kefiw"
  description="Compare roof, HVAC, remodel, and home repair quotes by normalized scope, exclusions, warranty, documents, timeline, risk, and cash exposure."
  canonical="/property/quote-comparison/"
  keywords={['contractor quote comparison', 'compare contractor bids', 'home repair quote checklist', 'roof quote comparison']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/property/', label: 'Property' },
    { href: '/property/quote-comparison/', label: 'Quote Comparison' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Comparison</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Contractor Quote Comparison Matrix</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Normalize bids before you pick the low number. Compare scope clarity, excluded work, proof, warranty, timeline, cash exposure, and risk.
      </p>
    </header>

    <PropertyComparisonWorkbench client:load defaultMode="contractor" />

    <section class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/contractor-signing-checklist/">
        <div class="text-sm font-semibold">Contractor signing checklist</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Scope, exclusions, warranty, payment terms, change orders, and completion proof.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/hvac-quote-documents/">
        <div class="text-sm font-semibold">HVAC quote documents</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Diagnosis evidence, equipment models, duct assumptions, warranty, and rebates.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/roof-claim-documents/">
        <div class="text-sm font-semibold">Roof claim documents</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Storm proof, adjuster scope, deductible math, and contractor scope.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/decision-packet/">
        <div class="text-sm font-semibold">Build decision packet</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Save the winning bid, missing scope, red flags, and next questions.</p>
      </a>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
