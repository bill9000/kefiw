---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import PropertyComparisonWorkbench from '~/components/property/PropertyComparisonWorkbench';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Property Option Comparison Matrix | Kefiw"
  description="Compare seller offers, buyer closing versions, repair credits, and property options by net value, cash impact, scope, paperwork, timing, and risk."
  canonical="/property/option-comparison/"
  keywords={['property option comparison', 'seller offer comparison', 'repair credit comparison', 'closing cost comparison']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/property/', label: 'Property' },
    { href: '/property/option-comparison/', label: 'Option Comparison' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Comparison</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Property Option Comparison Matrix</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Compare offers, closing versions, repair credits, and alternatives by more than the headline number.
      </p>
    </header>

    <PropertyComparisonWorkbench client:load defaultMode="seller-offer" />

    <section class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/seller-net-sheet-documents/">
        <div class="text-sm font-semibold">Seller net sheet checklist</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Payoff, commission, concessions, title, tax, HOA, prep, and repair details.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/buyer-cash-to-close-documents/">
        <div class="text-sm font-semibold">Buyer cash checklist</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Loan estimate, title estimate, escrow, prepaids, credits, and reserves.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/hoa-title-closing-documents/">
        <div class="text-sm font-semibold">HOA and title checklist</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Title lines, tax proration, payoff timing, resale docs, transfer fees, and dues.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/decision-packet/">
        <div class="text-sm font-semibold">Build decision packet</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Package option ranking, cash impact, open questions, and risk checks.</p>
      </a>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
