---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import PropertyDecisionPacket from '~/components/property/PropertyDecisionPacket';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Property Decision Packet Builder | Kefiw"
  description="Build a printable property decision packet with estimates, quote differences, missing scope, red flags, documents, questions, next steps, and risk checks."
  canonical="/property/decision-packet/"
  keywords={['property decision packet', 'home repair decision checklist', 'contractor quote checklist', 'real estate decision summary']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/property/', label: 'Property' },
    { href: '/property/decision-packet/', label: 'Decision Packet' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Output</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Property Decision Packet</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Turn calculators, guides, quotes, documents, and open questions into one packet before you sign, list, buy, claim, repair, or replace.
      </p>
      <p class="mt-3 max-w-3xl rounded-md border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm leading-6 text-cyan-950">
        Use this to make the decision auditable: what number you got, what could be missing, what would make it fail, and who should verify it.
      </p>
    </header>

    <PropertyDecisionPacket client:load />

    <section class="mt-10 rounded-lg border border-slate-200 bg-white p-4">
      <h2 class="text-lg font-semibold text-slate-900">Useful inputs before you build the packet</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/start/">Property Start Here</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/playbooks/">Property Playbooks</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/checklists/">Property Checklists</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/quote-comparison/">Quote Comparison</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/option-comparison/">Option Comparison</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/rental-investor-planner/">Rental Investor Planner</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/seller-proceeds-calculator/">Seller Proceeds</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/property/hvac-diagnosis-live-matrix/">HVAC Diagnosis Matrix</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/homelab/roof-replacement-cost-calculator/">Roof Replacement Cost</a>
      </div>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
