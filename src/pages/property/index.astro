---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import PropertyCategoryCard from '~/components/PropertyCategoryCard.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { PROPERTY_CATEGORIES, propertyCategoryHref } from '~/data/property-categories';
import { PROPERTY_CHECKLISTS, propertyChecklistHref } from '~/data/property-checklists';
import { PROPERTY_PLAYBOOKS, propertyPlaybookHref } from '~/data/property-playbooks';
import { VERTICAL_CALCULATORS_BY_AREA, verticalCalculatorHref } from '~/data/vertical-calculators';

const propertyPages = VERTICAL_CALCULATORS_BY_AREA.property;
const pageBySlug = new Map(propertyPages.map((page) => [page.slug, page]));
const pagesFor = (slugs: string[]) =>
  slugs
    .map((slug) => pageBySlug.get(slug))
    .filter((page): page is NonNullable<typeof page> => Boolean(page));
const pageLinksFor = (slugs: string[]) =>
  pagesFor(slugs).map((page) => ({
    href: verticalCalculatorHref(page),
    title: page.h1,
    summary: page.summary,
  }));

const calculatorGroups = [
  {
    id: 'roof',
    title: 'Roof, storm, and insurance decisions',
    description: 'Roof work is a Property decision, not a separate Home Lab. Start with scope, repair-vs-replace, insurance, and discount paperwork before comparing bids.',
    links: [
      {
        href: '/homelab/roof-replacement-cost-calculator/',
        title: 'Roof Replacement Cost Calculator',
        summary: 'Estimate full roof cost, then test roof-over, owner materials, installer-only, flashing, and scope-trim strategies.',
      },
      {
        href: '/homelab/roof-repair-vs-replacement-calculator/',
        title: 'Roof Repair vs Replacement Calculator',
        summary: 'Compare age, damage, leaks, sale horizon, and insurance pressure before replacing the whole roof.',
      },
      {
        href: '/homelab/roof-insurance-deductible-calculator/',
        title: 'Roof Insurance Deductible Calculator',
        summary: 'Model deductible, ACV/RCV, depreciation holdback, code upgrades, and claim out-of-pocket cost.',
      },
      {
        href: '/homelab/hail-damage-severity-estimator/',
        title: 'Hail Damage Severity Estimator',
        summary: 'Check claim strength, hail/wind evidence, maintenance risks, tree-rub issues, and adjuster questions.',
      },
      {
        href: '/guides/save-on-roof-replacement-cost/',
        title: 'How to Save on Roof Replacement Cost',
        summary: 'Real homeowner tactics: bid scope, roof-over, material ordering, installer-only bids, flashing decisions, and hidden risks.',
      },
      {
        href: '/guides/roof-hail-wind-insurance-discounts/',
        title: 'Roof Hail and Wind Insurance Discounts',
        summary: 'Class 3/Class 4 impact paperwork, wind forms, nail patterns, and documentation to collect before final payment.',
      },
    ],
  },
  {
    id: 'improve',
    title: 'HVAC and energy decisions',
    description: 'Diagnosis, replacement, repair-vs-replace, duct, and energy decisions. These should answer what to do before they answer what it costs.',
    links: pageLinksFor([
      'hvac-diagnosis-live-matrix',
      'hvac-load-estimate',
      'hvac-replacement-cost',
      'hvac-repair-vs-replace',
      'ductwork-cost',
      'energy-savings-estimate',
    ]),
  },
  {
    id: 'sell',
    title: 'Sell and net sheet decisions',
    description: 'Prep, price, commission, closing costs, and seller proceeds. These tools should explain which line item changes the actual check.',
    links: pageLinksFor([
      'home-sale-prep-roi-calculator',
      'seller-proceeds-calculator',
      'net-sheet-calculator',
      'commission-calculator',
      'closing-cost-calculator',
    ]),
  },
  {
    id: 'closing-details',
    title: 'Closing line-item helpers',
    description: 'Use these when a title estimate, tax proration, resale certificate, or association fee needs its own line instead of being buried in a percentage.',
    links: pageLinksFor([
      'title-company-cost-calculator',
      'tax-proration-calculator',
      'resale-certificate-calculator',
      'association-dues-calculator',
      'association-transfer-fee-calculator',
    ]),
  },
  {
    id: 'buy',
    title: 'Buy and cash-to-close decisions',
    description: 'Buyer cash requirements, mortgage math, and rent-vs-buy timing.',
    links: pageLinksFor(['cash-to-close-calculator']),
  },
];

const decisionQuestions = [
  {
    title: 'Am I making a mistake?',
    body: 'Compare scope, proof, cash exposure, warranty, contract terms, and timing before comparing final prices.',
  },
  {
    title: 'What am I forgetting?',
    body: 'Look for hidden line items: decking, ducts, title fees, tax proration, HOA documents, concessions, insurance holdbacks, and repair reserves.',
  },
  {
    title: 'What would make this go bad?',
    body: 'A decision usually fails through missing scope, optimistic assumptions, verbal promises, unclear paperwork, or no backup plan.',
  },
  {
    title: 'What should I do next?',
    body: 'Run the right calculator, read the mistake-check guide, then collect everything into a decision packet before signing or spending.',
  },
];

const workbenchLinks = [
  {
    href: '/property/quote-comparison/',
    eyebrow: 'Contractors',
    title: 'Quote Comparison Matrix',
    summary: 'Normalize bids by scope, exclusions, proof, warranty, timeline, cash exposure, and risk.',
  },
  {
    href: '/property/option-comparison/',
    eyebrow: 'Offers',
    title: 'Option Comparison Matrix',
    summary: 'Compare seller offers, buyer closing versions, repair credits, and alternatives beyond headline price.',
  },
  {
    href: '/property/checklists/',
    eyebrow: 'Documents',
    title: 'Property Document Checklists',
    summary: 'Collect claim, quote, closing, title, HOA, seller, buyer, and rental due diligence documents before acting.',
  },
  {
    href: '/property/rental-investor-planner/',
    eyebrow: 'Invest',
    title: 'Rental Investor Planner',
    summary: 'Stress-test cash flow, cap rate, cash-on-cash return, DSCR, vacancy, repairs, capex, and reserves.',
  },
];
---

<BaseLayout
  title="Property Calculators — Seller, Buyer, Owner, and Rental Tools | Kefiw"
  description="Property calculators for selling, buying, owning, refinancing, and rental investing. Seller proceeds, cash to close, mortgage math, cap rate, and cash-flow planning."
  canonical="/property/"
  keywords={['property calculators', 'seller proceeds calculator', 'closing costs calculator', 'cash to close calculator', 'rental property calculator']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/property/', label: 'Property' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Property decisions, made harder to mess up.</h1>
      <p class="mt-3 text-slate-700">
        Real-estate calculators belong in their own vertical: selling, buying, owning, repairing, and investing have different questions than generic finance.
        This hub is approved by realtor review for real-estate workflow and by engineering and scientific review for calculator and assumption framing.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800" href="/property/start/">
          Start here
        </a>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/property/decision-packet/">
          Build decision packet
        </a>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/">
          Use checklists
        </a>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href="/tracks/#property-tracks">
          Use a track
        </a>
      </div>
    </header>

    <section class="mb-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {decisionQuestions.map((item) => (
        <section class="rounded-lg border border-brand-200 bg-brand-50 p-4">
          <h2 class="text-base font-semibold text-slate-950">{item.title}</h2>
          <p class="mt-2 text-sm leading-6 text-slate-700">{item.body}</p>
        </section>
      ))}
    </section>

    <section class="mb-10">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-900">Choose the property decision</h2>
          <p class="mt-1 max-w-3xl text-sm leading-6 text-slate-600">
            Each section combines calculators with the mistake checks, missing items, and failure modes that usually matter more than the raw number.
          </p>
        </div>
        <a class="text-sm font-semibold text-brand-700 hover:underline" href="/property/start/">Not sure? Use Start Here</a>
      </div>
      <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {PROPERTY_CATEGORIES.map((category) => (
          <PropertyCategoryCard card={{ title: category.label, href: propertyCategoryHref(category.slug), text: category.intro, eyebrow: category.slug === 'guides' ? 'Guide system' : 'Decision area' }} />
        ))}
      </div>
    </section>

    <section class="mb-10">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Decision workbenches</p>
          <h2 class="mt-1 text-xl font-semibold text-slate-900">When the number is not enough</h2>
          <p class="mt-1 max-w-3xl text-sm leading-6 text-slate-600">
            These surfaces answer the real follow-up questions: what am I forgetting, which option is cleaner, what documents prove this, and whether the deal is still worth it.
          </p>
        </div>
        <a class="text-sm font-semibold text-brand-700 hover:underline" href="/property/decision-packet/">Package the answer</a>
      </div>
      <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {workbenchLinks.map((item) => (
          <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm" href={item.href}>
            <div class="text-xs font-semibold uppercase tracking-wide text-brand-700">{item.eyebrow}</div>
            <h3 class="mt-1 text-base font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.summary}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Scenario playbooks</p>
          <h2 class="mt-1 text-xl font-semibold text-slate-900">What should I do this week?</h2>
          <p class="mt-1 max-w-3xl text-sm leading-6 text-slate-600">
            Use these when the decision starts as pressure, not math: storm damage, dead AC, concessions, low bids, repair prep, or a closing surprise.
          </p>
        </div>
        <a class="text-sm font-semibold text-brand-700 hover:underline" href="/property/playbooks/">All property playbooks</a>
      </div>
      <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {PROPERTY_PLAYBOOKS.slice(0, 6).map((playbook) => (
          <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-slate-900 no-underline transition hover:border-brand-400 hover:bg-white" href={propertyPlaybookHref(playbook)}>
            <div class="text-sm font-semibold text-brand-800">{playbook.h1}</div>
            <div class="mt-1 text-xs leading-5 text-slate-600">{playbook.trigger}</div>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Document layer</p>
          <h2 class="mt-1 text-xl font-semibold text-slate-900">What should I collect before I trust this?</h2>
          <p class="mt-1 max-w-3xl text-sm leading-6 text-slate-600">
            Checklists make the calculators feel less thin because they turn a result into evidence, missing documents, and verification questions.
          </p>
        </div>
        <a class="text-sm font-semibold text-brand-700 hover:underline" href="/property/checklists/">All checklists</a>
      </div>
      <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {PROPERTY_CHECKLISTS.slice(0, 6).map((checklist) => (
          <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-slate-900 no-underline transition hover:border-brand-400 hover:bg-white" href={propertyChecklistHref(checklist)}>
            <div class="text-sm font-semibold text-brand-800">{checklist.h1}</div>
            <div class="mt-1 text-xs leading-5 text-slate-600">{checklist.trigger}</div>
          </a>
        ))}
      </div>
    </section>

    <section id="calculators" class="grid gap-4 md:grid-cols-2">
      {calculatorGroups.map((group) => (
        <section id={group.id} class="rounded-lg border border-slate-200 bg-white p-4">
          <h2 class="text-lg font-semibold text-slate-900">{group.title}</h2>
          <p class="mt-1 text-sm text-slate-600">{group.description}</p>
          <div class="mt-3 grid gap-2">
            {group.links.map((item) => (
              <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-slate-900 no-underline transition hover:border-brand-300 hover:bg-white" href={item.href}>
                <div class="text-sm font-semibold text-brand-800">{item.title}</div>
                <div class="mt-1 text-xs text-slate-600">{item.summary}</div>
              </a>
            ))}
            {group.id === 'buy' && (
              <>
                <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-slate-900 no-underline transition hover:border-brand-300 hover:bg-white" href="/calculators/mortgage-calculator/">
                  <div class="text-sm font-semibold text-brand-800">Mortgage Calculator</div>
                  <div class="mt-1 text-xs text-slate-600">Monthly payment, loan balance, and affordability context.</div>
                </a>
                <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-slate-900 no-underline transition hover:border-brand-300 hover:bg-white" href="/finance/horizon-point/">
                  <div class="text-sm font-semibold text-brand-800">Rent vs Buy / Horizon Point</div>
                  <div class="mt-1 text-xs text-slate-600">Compare ownership horizon against renting and transaction costs.</div>
                </a>
              </>
            )}
          </div>
        </section>
      ))}

      <section id="tracks" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Property tracks</h2>
        <p class="mt-1 text-sm text-slate-600">Guided workflows connect calculators into final plans.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/tracks/replace-my-roof/">Replace My Roof</a></li>
          <li><a class="text-brand-700 hover:underline" href="/tracks/replace-my-hvac/">Replace My HVAC</a></li>
          <li><a class="text-brand-700 hover:underline" href="/tracks/sell-my-home/">Sell My Home</a></li>
        </ul>
      </section>

      <section id="invest" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Rental and investment property</h2>
        <p class="mt-1 text-sm text-slate-600">Stress-test rent, vacancy, expenses, debt, reserves, due diligence, and hold horizon before treating a deal as good.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/property/invest/">Investment Property Hub</a></li>
          <li><a class="text-brand-700 hover:underline" href="/property/rental-investor-planner/">Rental Investor Planner</a></li>
          <li><a class="text-brand-700 hover:underline" href="/property/checklists/rental-due-diligence-documents/">Rental Due Diligence Checklist</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/mortgage-calculator/">Mortgage Calculator</a></li>
          <li><a class="text-brand-700 hover:underline" href="/finance/horizon-point/">Hold Horizon</a></li>
        </ul>
      </section>

      <section id="guides" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">High-value guides</h2>
          <p class="mt-1 text-sm text-slate-600">Practical counter-scope advice for expensive contractor decisions.</p>
          <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/guides/hvac-diagnosis-live-matrix/">HVAC Diagnosis Live Matrix</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/ac-dead-not-always-replacement/">Your AC Is Dead: Why That Does Not Always Mean Replacement</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/save-on-roof-replacement-cost/">How to Save on Roof Replacement Cost</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/roof-over-vs-tear-off/">Roof-over vs Tear-off</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/buy-roofing-materials-yourself/">Buying Roofing Materials Yourself</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/roof-hail-wind-insurance-discounts/">Roof Hail and Wind Insurance Discounts</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/hvac-full-replacement-alternatives/">Before You Replace Your HVAC</a></li>
          <li><a class="text-brand-700 hover:underline" href="/guides/mini-splits-vs-central-ac/">Mini-Splits vs Central AC</a></li>
        </ul>
      </section>
    </section>

    <section class="mt-8 rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-950">
      <h2 class="text-base font-semibold">Current approved tool coverage</h2>
      <p class="mt-1">
        Property now links real calculators for HVAC replacement, seller proceeds, closing costs, cash to close, title company costs,
        tax proration, resale certificates, association dues, association transfer fees, comparison workbenches, document checklists, and rental investor planning.
      </p>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
