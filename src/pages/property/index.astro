---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Property Lab — Seller, Buyer, Owner, and Rental Calculators | Kefiw"
  description="Property calculators for selling, buying, owning, refinancing, and rental investing. Seller proceeds, cash to close, mortgage math, cap rate, and cash-flow planning."
  canonical="/property/"
  keywords={['property calculators', 'seller proceeds calculator', 'closing costs calculator', 'cash to close calculator', 'rental property calculator']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/property/', label: 'Property' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Lab</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Property</h1>
      <p class="mt-3 text-slate-700">
        Real-estate calculators belong in their own vertical: selling, buying, owning, and investing have different questions than generic finance.
        This hub is approved by realtor review for real-estate workflow and by engineering and scientific review for calculator and assumption framing.
      </p>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      <section id="sell" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Sell</h2>
        <p class="mt-1 text-sm text-slate-600">Seller proceeds, closing costs, commission, prep ROI, and net sheet calculators.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="#sell">Seller Proceeds</a></li>
          <li><a class="text-brand-700 hover:underline" href="#sell">Closing Costs</a></li>
          <li><a class="text-brand-700 hover:underline" href="#sell">Net Sheet Calculator</a></li>
        </ul>
      </section>

      <section id="buy" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Buy</h2>
        <p class="mt-1 text-sm text-slate-600">Cash to close, rent vs buy, mortgage points, buydowns, and affordability.</p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><a class="text-brand-700 hover:underline" href="/calculators/mortgage-calculator/">Mortgage Calculator</a></li>
          <li><a class="text-brand-700 hover:underline" href="/calculators/mortgage-extra-payment-calculator/">Mortgage Extra Payment</a></li>
          <li><a class="text-brand-700 hover:underline" href="/finance/horizon-point/">Rent vs Buy / Horizon Point</a></li>
        </ul>
      </section>

      <section id="own" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Own</h2>
        <p class="mt-1 text-sm text-slate-600">Property tax, escrow, refinance break-even, home equity, and ownership cost planning.</p>
      </section>

      <section id="invest" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Invest</h2>
        <p class="mt-1 text-sm text-slate-600">Rental property, cap rate, cash flow, BRRRR, and short-term rental calculators.</p>
      </section>
    </div>

    <section class="mt-8 rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-950">
      <h2 class="text-base font-semibold">Current approved tool coverage</h2>
      <p class="mt-1">
        Existing mortgage and rent-vs-buy tools remain linked here while Property Lab groups the real-estate decision path under realtor-approved workflow language.
      </p>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
