---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import StartHerePropertyIntake from '~/components/property/StartHerePropertyIntake';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Not Sure Where to Start? Property Decision Intake | Kefiw"
  description="Answer a few property questions and get a recommended Kefiw path for roof, HVAC, selling, buying, closing costs, owner repairs, contractor quotes, and decision packets."
  canonical="/property/start/"
  keywords={['property decision intake', 'property start here', 'home repair decision tool', 'real estate calculator guide']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/property/', label: 'Property' },
    { href: '/property/start/', label: 'Start Here' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Property Start Here</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Not sure where to start?</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Answer a few questions and Kefiw will route you to a practical next step: a calculator, guide, track, or decision packet.
      </p>
      <p class="mt-3 max-w-3xl rounded-md border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm leading-6 text-cyan-950">
        The goal is not just the number. The goal is to find the mistake, missing scope, fragile assumption, and next question before the decision gets expensive.
      </p>
    </header>

    <StartHerePropertyIntake client:load />

    <section class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/decision-packet/">
        <div class="text-sm font-semibold">Build a decision packet</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Collect estimates, risks, documents, quote differences, and next questions.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/playbooks/">
        <div class="text-sm font-semibold">Open playbooks</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Use scenario plans for roof leaks, dead AC, low bids, concessions, and closing surprises.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/checklists/">
        <div class="text-sm font-semibold">Use checklists</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Collect the documents, proof, and questions that make an estimate trustworthy.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/quote-comparison/">
        <div class="text-sm font-semibold">Compare quotes</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Normalize contractor bids before choosing the low number.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/roof/">
        <div class="text-sm font-semibold">Roof decisions</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Roof replacement, insurance, hail, repair-vs-replace, and scope checks.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/hvac/">
        <div class="text-sm font-semibold">HVAC decisions</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Diagnosis, replacement, repair-vs-replace, ducts, and energy decisions.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/property/invest/">
        <div class="text-sm font-semibold">Investment property</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Stress-test rental cash flow, reserves, rules, and due diligence.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/tracks/#property-tracks">
        <div class="text-sm font-semibold">Use a track</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Follow roof, HVAC, remodel, and selling workflows in order.</p>
      </a>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
