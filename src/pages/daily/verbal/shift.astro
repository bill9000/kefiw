---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import VerbalShift from '~/components/daily/VerbalShift.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/verbal/', label: 'Kefiw Verbal' },
  { href: '/daily/verbal/shift/', label: 'Letter Shift' },
];
---

<BaseLayout
  title="Daily Letter Shift — align columns into real words"
  description="Five columns of letters. Compose real words using one letter from each, in order. Fresh puzzle daily at 4am ET."
  canonical="/daily/verbal/shift/"
  keywords={["daily word puzzle", "letter column game", "typeshift puzzle", "daily verbal game"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Letter Shift</h1>
      <p class="mt-1 text-slate-600">Type a word using one letter from each column, in order. Find all targets to clear.</p>
    </header>

    <VerbalShift client:only="react" />
    <DailyPracticeNote
      title="Letter Shift"
      trains="Letter Shift trains positional language memory: scanning columns, aligning candidates, and noticing when a near-word is not actually valid."
      scoring="Better scores come from building real words with fewer resets. The useful habit is checking constraints before committing a row."
      routine="Use it when you want a compact verbal puzzle that sits between spelling practice and pattern matching."
      href="/word-tools/pattern-solver/"
      linkLabel="Pattern Solver"
    />
  </article>
</BaseLayout>
