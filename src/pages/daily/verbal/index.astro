---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import { getPipeline } from '~/data/daily-pipelines';
import { getGame } from '~/data/daily-games';

const pipeline = getPipeline('verbal');
if (!pipeline) throw new Error('verbal pipeline not registered');
const games = pipeline.games.map((id) => {
  const g = getGame(id);
  if (!g) throw new Error(`unknown game id ${id}`);
  return g;
});

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/verbal/', label: 'Kefiw Verbal' },
];
---

<BaseLayout
  title="Kefiw Verbal — daily letter and word puzzles"
  description="Five letter-and-word puzzles: cryptogram, link grid, letter shift, mini crossword, word twist. One seeded puzzle each. Fresh set at 4am ET."
  canonical="/daily/verbal/"
  keywords={["daily word puzzle", "daily cryptogram", "letter puzzle game", "verbal brain training"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Kefiw Verbal</h1>
      <p class="mt-1 text-lg text-slate-700">Five letter-and-word puzzles. One per day. Same for everyone.</p>
      <p class="mt-2 max-w-3xl text-slate-600">
        Solve as much as you can at your own pace. There&rsquo;s no hard timer — but the longer you take, the lower your multiplier. A competent solver finishes a puzzle near its baseline; pros finish under it and earn the max 1.5× time bonus.
      </p>
    </header>

    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {games.map((g) => (
        <a
          href={`/daily/verbal/${g.slug}/`}
          class="block rounded-lg border border-slate-200 bg-white p-4 transition hover:border-brand-500 hover:shadow-md"
        >
          <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-600">{g.id.replace('verbal-', '')}</div>
          <div class="mt-1 text-lg font-bold text-slate-900">{g.name}</div>
          <p class="mt-2 text-sm text-slate-600">{g.blurb}</p>
          <div class="mt-3 text-xs text-slate-500">1 puzzle · soft time penalty · max 1500</div>
        </a>
      ))}
    </section>

    <section class="mt-8 flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 p-4">
      <div>
        <h2 class="text-lg font-semibold">Pipeline leaderboard</h2>
        <p class="text-sm text-slate-600">Sum of all five game scores across today. Top 50 shown.</p>
      </div>
      <a href="/daily/leaderboard/?pipeline=verbal" class="rounded bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">View ranks →</a>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-6">
      <h2 class="text-xl font-semibold">How scoring works</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-700">
        <li><strong>Accuracy first.</strong> Each game measures how much of the puzzle you got right (letters mapped, groups found, cells filled, words formed).</li>
        <li><strong>Time multiplier.</strong> Solve at or under the baseline time → ×1.5. Twice the baseline → ×1.0. Four times or more → ×0.3 floor.</li>
        <li><strong>No hard timer.</strong> Take as long as you need — the score just drops. Walking away mid-puzzle resumes where you left off.</li>
        <li><strong>Clear = 450+ / 1500.</strong> Hit that on all five today to extend the pipeline streak.</li>
      </ul>
    </section>

    <section class="mt-8 rounded-md border border-slate-200 bg-slate-50 p-4 text-xs text-slate-600">
      <strong>A note on cognitive training.</strong> This pipeline trains working memory for letters and letter-pattern recognition on the specific tasks — that&rsquo;s what the research supports. It is not a dementia-prevention or IQ-boost product. 15–25 minutes a day, four to five days a week, is the sweet spot per the cognitive-training literature.
    </section>
  </article>
</BaseLayout>
