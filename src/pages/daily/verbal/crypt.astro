---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import VerbalCrypt from '~/components/daily/VerbalCrypt.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/verbal/', label: 'Kefiw Verbal' },
  { href: '/daily/verbal/crypt/', label: 'Cryptogram' },
];
---

<BaseLayout
  title="Daily Cryptogram — today's substitution cipher puzzle"
  description="Decode today's cryptogram, one letter at a time. Fresh quote daily at 4am ET."
  canonical="/daily/verbal/crypt/"
  keywords={["daily cryptogram", "substitution cipher puzzle", "decode quote", "word puzzle"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Cryptogram</h1>
      <p class="mt-1 text-slate-600">Every cipher letter maps to one plaintext letter. Tap a letter in the quote, then pick what it decodes to.</p>
    </header>

    <VerbalCrypt client:only="react" />
    <DailyPracticeNote
      title="Cryptogram"
      trains="Cryptogram trains substitution reasoning: letter frequency, repeated patterns, common word shapes, and patient hypothesis testing."
      scoring="The best runs decode more of the quote with fewer false assumptions. The useful skill is holding a mapping in memory while revising it carefully."
      routine="Use it as a verbal warmup when you want slower, deliberate pattern recognition instead of a speed-only word game."
      href="/daily/verbal/"
      linkLabel="Kefiw Verbal"
    />
  </article>
</BaseLayout>
