---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import MathGame from '~/components/daily/MathGame.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/math/', label: 'Kefiw Math' },
  { href: '/daily/math/percent/', label: 'Percent Dash' },
];
---

<BaseLayout
  title="Percent Dash — daily mental percentage practice"
  description="Ten timed 'X% of Y' rounds. Tap the closest answer or type the exact. Same questions for every player each day. Fresh set at 4am ET."
  canonical="/daily/math/percent/"
  keywords={["mental percent math", "percent practice game", "daily math game", "10% of calculator"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Percent Dash</h1>
      <p class="mt-1 text-slate-600">Ten rounds. Fifteen seconds each. Faster answers score higher.</p>
    </header>

    <MathGame client:only="react" gameId="math-percent" title="Percent Dash" />
    <DailyPracticeNote
      title="Percent Dash"
      trains="Percent Dash trains fast proportional reasoning: turning X percent of Y into a clean mental estimate before choosing or typing the exact answer."
      scoring="Each daily set has ten timed rounds. Correct answers score higher when they are both accurate and quick, so the useful habit is controlled estimation rather than random tapping."
      routine="Use it as a short number-sense warmup before shopping, budgeting, pricing, or comparing options where percentages can distort the decision."
      href="/calculators/percentage-calculator/"
      linkLabel="Percentage Calculator"
    />
  </article>
</BaseLayout>
