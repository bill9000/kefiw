---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import MathGame from '~/components/daily/MathGame.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/math/', label: 'Kefiw Math' },
  { href: '/daily/math/convert/', label: 'Convert Sprint' },
];
---

<BaseLayout
  title="Convert Sprint — daily unit-conversion practice"
  description="Ten rounds of unit conversion: miles to km, °F to °C, lbs to kg, and more. Tap the closest or type the exact. Fresh set at 4am ET."
  canonical="/daily/math/convert/"
  keywords={["unit conversion practice", "mental conversion game", "daily math game", "miles to km practice"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Convert Sprint</h1>
      <p class="mt-1 text-slate-600">Mental unit conversion. Ten rounds. Fifteen seconds each.</p>
    </header>

    <MathGame client:only="react" gameId="math-convert" title="Convert Sprint" />
    <DailyPracticeNote
      title="Convert Sprint"
      trains="Convert Sprint trains unit sense: miles to kilometers, pounds to kilograms, Fahrenheit to Celsius, and other everyday conversions."
      scoring="Each round rewards a close and fast conversion. Good play means remembering anchor values and checking whether the answer is plausible."
      routine="Use it as a quick calibration drill before travel, cooking, shipping, fitness, or project planning where wrong units can create bad assumptions."
      href="/converters/"
      linkLabel="Conversion Tools"
    />
  </article>
</BaseLayout>
