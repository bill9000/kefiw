---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import SpatialGame from '~/components/daily/SpatialGame.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/spatial/', label: 'Kefiw Spatial' },
  { href: '/daily/spatial/pair/', label: 'Tile Pair' },
];
---

<BaseLayout
  title="Daily Tile Pair — mental-rotation practice"
  description="Ten quick rounds: match the shape to its rotated twin. Fresh puzzle daily at 4am ET."
  canonical="/daily/spatial/pair/"
  keywords={["mental rotation game", "spatial matching daily", "shape rotation puzzle"]}
>
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Tile Pair</h1>
      <p class="mt-1 text-slate-600">Ten rounds. Find the rotated twin of the target shape.</p>
    </header>
    <SpatialGame client:only="react" gameId="spatial-pair" title="Tile Pair" />
    <DailyPracticeNote
      title="Tile Pair"
      trains="Tile Pair trains mental rotation: holding a target shape in memory while checking whether another tile matches after rotation."
      scoring="A correct rotated match scores best when chosen quickly. The useful habit is comparing stable features instead of relying on the first visual impression."
      routine="Use it as a short spatial-reasoning drill for attention, orientation, and shape comparison."
      href="/daily/spatial/"
      linkLabel="Kefiw Spatial"
    />
  </article>
</BaseLayout>
