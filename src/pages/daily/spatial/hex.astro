---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import SpatialGame from '~/components/daily/SpatialGame.tsx';
import DailyPracticeNote from '~/components/daily/DailyPracticeNote.astro';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/spatial/', label: 'Kefiw Spatial' },
  { href: '/daily/spatial/hex/', label: 'Hex Fit' },
];
---

<BaseLayout
  title="Daily Hex Fit — shape-matching puzzle"
  description="Ten quick rounds: pick the hex piece that fits the gap. Fresh puzzle daily at 4am ET."
  canonical="/daily/spatial/hex/"
  keywords={["hex fit puzzle", "shape matching daily", "spatial fit game"]}
>
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Hex Fit</h1>
      <p class="mt-1 text-slate-600">Ten rounds. Pick the piece that fills the gap.</p>
    </header>
    <SpatialGame client:only="react" gameId="spatial-hex" title="Hex Fit" />
    <DailyPracticeNote
      title="Hex Fit"
      trains="Hex Fit trains shape fitting: checking edges, angles, and empty space before selecting the piece that belongs in the gap."
      scoring="Correct fits score higher when chosen quickly. Strong play means eliminating pieces that almost fit but break one edge or corner."
      routine="Use it as a visual pattern drill when you want compact spatial practice without a large board or long session."
      href="/daily/spatial/"
      linkLabel="Kefiw Spatial"
    />
  </article>
</BaseLayout>
