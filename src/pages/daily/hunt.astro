---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import HuntGame from '~/components/daily/HuntGame.tsx';
import Leaderboard from '~/components/daily/Leaderboard.tsx';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/hunt/', label: 'Five-Letter Hunt' },
];
---

<BaseLayout
  title="Daily Five-Letter Hunt — Kefiw"
  description="Crack today's 5-letter word in six guesses. New word every day at 4am ET."
  canonical="/daily/hunt/"
  keywords={["five letter word game", "daily word puzzle", "word hunt", "wordle alternative"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Five-Letter Hunt</h1>
      <p class="mt-1 text-slate-600">Six guesses. One word. Green = right spot, yellow = wrong spot.</p>
    </header>

    <HuntGame client:only="react" />

    <section class="mx-auto mt-8 max-w-3xl rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Why Five-Letter Hunt is in Kefiw Daily</h2>
      <div class="mt-3 grid gap-4 text-sm leading-6 text-slate-700 md:grid-cols-2">
        <div>
          <h3 class="font-semibold text-slate-900">What it trains</h3>
          <p class="mt-1">
            Five-Letter Hunt is a constraint-solving drill. Each guess tests a hypothesis,
            then the color feedback narrows the search space for the next decision.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">How scoring works</h3>
          <p class="mt-1">
            Lower guess counts rank better. Good play balances information gathering,
            letter-position memory, and avoiding repeated letters that feedback has ruled out.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">Privacy</h3>
          <p class="mt-1">
            Your current board and local streak stay in the browser. Leaderboard posting is separate
            from the playable round.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">Use it with</h3>
          <p class="mt-1">
            After playing, use the <a href="/word-tools/pattern-solver/" class="text-brand-700 underline">Pattern Solver</a>
            to study how letter constraints change the possible answer set.
          </p>
        </div>
        <div class="md:col-span-2">
          <h3 class="font-semibold text-slate-900">How to make the practice useful</h3>
          <p class="mt-1">
            The useful review is not only whether you solved the word. Look at the guess that changed the
            board the most. Did it test new letters, confirm a position, or waste a slot on something feedback
            had already ruled out? Naming that decision rule helps the next round feel less like guessing and
            more like controlled search.
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto mt-8 max-w-md">
      <h2 class="mb-3 text-lg font-semibold">Today's top solvers</h2>
      <Leaderboard client:only="react" gameId="hunt" limit={20} />
      <p class="mt-3 text-center text-xs text-slate-500">
        <a href="/daily/leaderboard/" class="text-brand-700 hover:underline">All three boards →</a>
      </p>
    </section>
  </article>
</BaseLayout>
