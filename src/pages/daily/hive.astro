---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import HiveGame from '~/components/daily/HiveGame.tsx';
import Leaderboard from '~/components/daily/Leaderboard.tsx';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/daily/', label: 'Daily Kefiw' },
  { href: '/daily/hive/', label: 'Hive' },
];
---

<BaseLayout
  title="Daily Hive — Kefiw"
  description="Find every word using today's seven letters. The center letter must appear in every word. Reach Good tier to clear the day."
  canonical="/daily/hive/"
  keywords={["spelling bee alternative", "daily hive", "letter puzzle", "word finder game"]}
>
  <Breadcrumb crumbs={crumbs} />

  <article class="container-wide py-6">
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight">Hive</h1>
      <p class="mt-1 text-slate-600">Four-letter minimum. Every word must contain the center letter.</p>
    </header>

    <HiveGame client:only="react" />

    <section class="mx-auto mt-8 max-w-3xl rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-slate-900">Why Hive is in Kefiw Daily</h2>
      <div class="mt-3 grid gap-4 text-sm leading-6 text-slate-700 md:grid-cols-2">
        <div>
          <h3 class="font-semibold text-slate-900">What it trains</h3>
          <p class="mt-1">
            Hive is a language-pattern drill. It asks you to hold seven letters in working memory,
            test prefixes and suffixes, and keep returning to the center-letter constraint.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">How scoring works</h3>
          <p class="mt-1">
            Longer words are worth more, and every accepted word must use the center letter.
            The goal is steady recall and pattern coverage, not guessing fast at random.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">Privacy</h3>
          <p class="mt-1">
            Puzzle state and streak signals are kept locally in your browser unless you choose
            to submit a leaderboard score.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900">Use it with</h3>
          <p class="mt-1">
            Pair Hive with <a href="/word-tools/word-finder/" class="text-brand-700 underline">Word Finder</a>
            after the round to review missed patterns without turning the puzzle into a lookup task.
          </p>
        </div>
        <div class="md:col-span-2">
          <h3 class="font-semibold text-slate-900">How to make the practice useful</h3>
          <p class="mt-1">
            Do not treat the score as a vocabulary verdict. Hive is most useful when you review the shape of
            the words you missed: common endings, compound forms, repeated vowel patterns, or prefixes that
            fit the center-letter rule. After the round, write down one pattern you overlooked and try to find
            two more words from that same pattern before opening a solver. That keeps the page in the
            cognitive-practice lane instead of becoming a pure word lookup.
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto mt-8 max-w-lg">
      <h2 class="mb-3 text-lg font-semibold">Today's top scorers</h2>
      <Leaderboard client:only="react" gameId="hive" limit={20} />
      <p class="mt-3 text-center text-xs text-slate-500">
        <a href="/daily/leaderboard/" class="text-brand-700 hover:underline">All three boards →</a>
      </p>
    </section>
  </article>
</BaseLayout>
