---
import ToolLayout from '~/layouts/ToolLayout.astro';
import { TOOLS_BY_ID } from '~/data/tools';
import Island from '~/components/tools/DailyAnagram.tsx';
const tool = TOOLS_BY_ID['daily-word'];
---
<ToolLayout tool={tool}>
  <Island client:load length={5} storageNamespace="daily-word" variantLabel="Daily Word" />
</ToolLayout>
