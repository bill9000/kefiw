---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import FamilyCarePlanSummaryIsland from '~/components/care/FamilyCarePlanSummary';
import CareTrustFooter from '~/components/CareTrustFooter.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Family Care Plan Summary Builder | Kefiw"
  description="Build a printable family care plan summary with care concerns, green/yellow/red needs, cost estimates, caregiver hours, documents, questions, and next steps."
  canonical="/care/family-care-plan-summary/"
  keywords={['family care plan summary', 'senior care plan template', 'caregiver summary', 'family care planning worksheet']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/care/', label: 'Care' },
    { href: '/care/family-care-plan-summary/', label: 'Family Care Plan Summary' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Care Plan Output</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Family Care Plan Summary</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Turn calculators, worksheets, and family notes into one printable summary for siblings, providers, facility tours, attorneys, advisors, or the next care meeting.
      </p>
      <p class="mt-3 max-w-3xl rounded-md border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm leading-6 text-cyan-950">
        Use initials when possible, avoid full account numbers, and share sensitive care, financial, legal, or medication details only with appropriate people.
      </p>
    </header>

    <FamilyCarePlanSummaryIsland client:load />

    <section class="mt-10 rounded-lg border border-slate-200 bg-white p-4">
      <h2 class="text-lg font-semibold text-slate-900">Useful inputs before you build the summary</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/care/care-needs-checklist/">Care Needs Checklist</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/care/caregiver-hours-calculator/">Caregiver Hours Calculator</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/care/senior-care-cost-calculator/">Senior Care Cost Calculator</a>
        <a class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm font-semibold text-brand-700 no-underline hover:border-brand-400" href="/care/guides/document-storage-access-update-checklist/">Document Storage Checklist</a>
      </div>
    </section>

    <CareTrustFooter variant="guide" />
    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'registered nurse', href: '/registered-nurse-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
      includeHealthDisclaimer
    />
  </article>
</BaseLayout>
