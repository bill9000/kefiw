---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import StartHereCareIntake from '~/components/care/StartHereCareIntake';
import CareTrustFooter from '~/components/CareTrustFooter.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Not Sure Where to Start? Care Planning Intake | Kefiw"
  description="Answer a few care planning questions and get a recommended Kefiw path for safety, cost, caregiver workload, memory, facility decisions, Medicare, or insurance."
  canonical="/care/start/"
  keywords={['care planning intake', 'senior care start here', 'caregiver decision path', 'care planning assistant']}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/care/', label: 'Care' },
    { href: '/care/start/', label: 'Start Here' },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Start Here</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Not sure where to start?</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">
        Answer a few questions and Kefiw will route you to a practical next step: a calculator, worksheet, playbook, guide, or care track.
      </p>
      <p class="mt-3 max-w-3xl rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm leading-6 text-amber-950">
        If someone may be experiencing a medical emergency or immediate danger, call emergency services now. Do not use this intake instead of emergency care.
      </p>
    </header>

    <StartHereCareIntake client:load />

    <section class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/care/family-care-plan-summary/">
        <div class="text-sm font-semibold">Build a family summary</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Turn the recommended path into a printable family care plan.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/care/playbooks/">
        <div class="text-sm font-semibold">Open playbooks</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Use scenario plans for falls, discharge, cost, dementia, burnout, and facility decisions.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/tracks/plan-senior-care/">
        <div class="text-sm font-semibold">Use a care track</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Work through care needs, cost, workload, Medicare, and family ownership in order.</p>
      </a>
      <a class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline hover:border-brand-400" href="/care/guides/">
        <div class="text-sm font-semibold">Browse care guides</div>
        <p class="mt-1 text-xs leading-5 text-slate-600">Go directly to the full guide library if you already know the topic.</p>
      </a>
    </section>

    <CareTrustFooter variant="guide" />
    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'registered nurse', href: '/registered-nurse-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
      includeHealthDisclaimer
    />
  </article>
</BaseLayout>
