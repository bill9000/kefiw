---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
---

<BaseLayout
  title="Care Lab — Senior Care, Caregiving, Medicare, and Insurance Calculators | Kefiw"
  description="Care planning calculators for senior care costs, assisted living, memory care, home care, caregiving hours, Medicare costs, and insurance planning."
  canonical="/care/"
  keywords={['care calculators', 'senior care cost calculator', 'assisted living cost calculator', 'caregiver hours calculator', 'medicare cost calculator']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/care/', label: 'Care' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Care Lab</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Care</h1>
      <p class="mt-3 text-slate-700">
        Care-cost planning is different from generic health content. The focus here is family budgeting, care workload,
        Medicare and insurance costs, and safety-aware planning language approved by registered nurse review.
      </p>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      <section id="senior-care" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Senior Care</h2>
        <p class="mt-1 text-sm text-slate-600">Senior care cost, assisted living, nursing home, memory care, and home care calculators.</p>
      </section>

      <section id="caregiving" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Caregiving</h2>
        <p class="mt-1 text-sm text-slate-600">Caregiver hours, family care budget, respite care cost, and care-needs checklists.</p>
      </section>

      <section id="medicare" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Medicare</h2>
        <p class="mt-1 text-sm text-slate-600">Medicare cost, IRMAA, Part B premiums, and Part D estimates.</p>
      </section>

      <section id="insurance" class="rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Insurance</h2>
        <p class="mt-1 text-sm text-slate-600">HSA/FSA, health insurance cost, and long-term care insurance calculators.</p>
      </section>
    </div>

    <section class="mt-8 rounded-lg border border-cyan-200 bg-cyan-50 p-4 text-sm text-cyan-950">
      <h2 class="text-base font-semibold">Existing health tools</h2>
      <p class="mt-1">
        Deterministic health tools remain in the <a href="/health/" class="font-semibold underline">Health suite</a>.
        Care will lead with planning, costs, and family decisions rather than generic symptom or diagnosis pages.
      </p>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'registered nurse', href: '/registered-nurse-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
      includeHealthDisclaimer
    />
  </article>
</BaseLayout>
