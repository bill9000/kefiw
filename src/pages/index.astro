---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ToolCard from '~/components/ToolCard.astro';
import PopularTools from '~/components/PopularTools.astro';
import FeaturedClusters from '~/components/FeaturedClusters.astro';
import AdSlot from '~/components/AdSlot.astro';
import { CATEGORIES, toolsByCategory } from '~/data/tools';
import { getPopularTools } from '~/data/popular-tools';

const popular = getPopularTools({ mode: 'fallback', limit: 5 });
const clusterSlugs = ['scrabble', 'unscramble', 'pattern', 'rhyme', 'everyday-calculators', 'daily'];

const siteBase = (Astro.site?.toString() ?? 'https://kefiw.com').replace(/\/$/, '');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteBase}/#organization`,
      name: 'Kefiw',
      url: `${siteBase}/`,
      logo: {
        '@type': 'ImageObject',
        url: `${siteBase}/og-image.png`,
        width: 1200,
        height: 630,
      },
      description: 'Kefiw connects calculators, guides, and tracks into practical decision plans for property, business, care, everyday tools, and cognitive play.',
    },
    {
      '@type': 'WebSite',
      '@id': `${siteBase}/#website`,
      name: 'Kefiw',
      url: `${siteBase}/`,
      publisher: { '@id': `${siteBase}/#organization` },
      inLanguage: 'en',
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${siteBase}/?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---
<BaseLayout
  title="Kefiw — Calculators, Tracks, and Practical Decision Guides"
  description="Kefiw helps you plan property, business, care, and everyday decisions with calculators, guided tracks, practical guides, and daily cognitive puzzle tools."
  canonical="/"
  keywords={['word tools', 'unscrambler', 'anagram solver', 'converters', 'calculators', 'decision tools', 'daily challenges']}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <section class="container-wide py-8 sm:py-12">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Kefiw</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Decision tools that turn numbers into next steps.</h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600">
      Use Kefiw to estimate costs, compare options, stress-test assumptions, and follow guided tracks across property,
      business, care, everyday tools, and cognitive play.
    </p>
    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a href="/property/" class="rounded-md border border-slate-200 bg-white p-4 no-underline transition hover:border-brand-300 hover:bg-brand-50">
        <div class="text-sm font-semibold text-slate-900">Property</div>
        <div class="mt-1 text-xs leading-5 text-slate-600">Improve, estimate, buy, sell, own, invest, and insure.</div>
      </a>
      <a href="/business/" class="rounded-md border border-slate-200 bg-white p-4 no-underline transition hover:border-brand-300 hover:bg-brand-50">
        <div class="text-sm font-semibold text-slate-900">Business</div>
        <div class="mt-1 text-xs leading-5 text-slate-600">Tax, pricing, hiring, revenue, and cloud planning.</div>
      </a>
      <a href="/care/" class="rounded-md border border-slate-200 bg-white p-4 no-underline transition hover:border-brand-300 hover:bg-brand-50">
        <div class="text-sm font-semibold text-slate-900">Care</div>
        <div class="mt-1 text-xs leading-5 text-slate-600">Senior care, caregiving, Medicare, insurance, and wellbeing.</div>
      </a>
      <a href="/tracks/" class="rounded-md border border-slate-200 bg-white p-4 no-underline transition hover:border-brand-300 hover:bg-brand-50">
        <div class="text-sm font-semibold text-slate-900">Tracks</div>
        <div class="mt-1 text-xs leading-5 text-slate-600">Guided pipelines that turn related tools into a plan.</div>
      </a>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <a href="/calculators/" class="btn-ghost">Tools</a>
      <a href="/games/" class="btn-ghost">Cognitive Play</a>
      <a href="/guides/" class="btn-ghost">Guides</a>
      <a href="/word-tools/" class="btn-ghost">Word Tools</a>
      <a href="/converters/" class="btn-ghost">Converters</a>
    </div>
  </section>

  <aside class="border-y border-cyan-200 bg-gradient-to-r from-cyan-50 via-cyan-50 to-white">
    <div class="container-wide py-4">
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center rounded-full bg-cyan-600 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">Daily</span>
        <p class="text-sm font-semibold text-cyan-900">
          Short, repeatable cognitive play for words, numbers, visual patterns, and logic —
          <a href="/guides/word-games-and-puzzles-brain-health-routine/" class="underline hover:text-cyan-700">not a cure, not a diagnosis</a>,
          just a thinking routine you&rsquo;ll actually keep.
        </p>
      </div>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/daily/" class="group flex items-start justify-between gap-3 rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:shadow-sm">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Kefiw Daily</div>
            <div class="mt-0.5 text-sm font-bold text-slate-900">Word — Hunt, Hive, Sudoku</div>
            <div class="mt-0.5 text-xs text-slate-600">Three puzzles, ~10 min at 4am ET.</div>
          </div>
          <span class="self-center text-cyan-600 group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="/daily/math/" class="group flex items-start justify-between gap-3 rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:shadow-sm">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Kefiw Math</div>
            <div class="mt-0.5 text-sm font-bold text-slate-900">Math — 5 arithmetic dashes</div>
            <div class="mt-0.5 text-xs text-slate-600">Percent, discount, convert, tip, date. ~12 min.</div>
          </div>
          <span class="self-center text-cyan-600 group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="/daily/verbal/" class="group flex items-start justify-between gap-3 rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:shadow-sm">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Kefiw Verbal</div>
            <div class="mt-0.5 text-sm font-bold text-slate-900">Verbal — 5 letter puzzles</div>
            <div class="mt-0.5 text-xs text-slate-600">Cryptogram, link, shift, crosser, twist. ~15 min.</div>
          </div>
          <span class="self-center text-cyan-600 group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="/daily/spatial/" class="group flex items-start justify-between gap-3 rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:shadow-sm">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Kefiw Spatial</div>
            <div class="mt-0.5 text-sm font-bold text-slate-900">Spatial — 5 visual pattern dashes</div>
            <div class="mt-0.5 text-xs text-slate-600">Circuit, drop, pair, hex, path. ~12 min.</div>
          </div>
          <span class="self-center text-cyan-600 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>
  </aside>

  <PopularTools tools={popular} />

  <FeaturedClusters slugs={clusterSlugs} />

  <AdSlot slot="between-sections" />

  {(['word-tools','converters','calculators','games'] as const).map((cat) => (
    <section class="container-wide mt-10">
      <div class="flex items-baseline justify-between">
        <h2 class="text-xl font-semibold">{CATEGORIES[cat].title}</h2>
        <a href={`/${cat}/`} class="text-sm">See all →</a>
      </div>
      <p class="mt-1 text-sm text-slate-600">{CATEGORIES[cat].blurb}</p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {toolsByCategory(cat).slice(0, 6).map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  ))}
</BaseLayout>
