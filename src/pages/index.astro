---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ToolCard from '~/components/ToolCard.astro';
import PopularTools from '~/components/PopularTools.astro';
import FeaturedClusters from '~/components/FeaturedClusters.astro';
import AdSlot from '~/components/AdSlot.astro';
import { CATEGORIES, toolsByCategory } from '~/data/tools';
import { getPopularTools } from '~/data/popular-tools';

const popular = getPopularTools({ mode: 'fallback', limit: 5 });
const clusterSlugs = ['scrabble', 'unscramble', 'pattern', 'rhyme', 'everyday-calculators', 'daily'];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kefiw',
  url: Astro.site?.toString() ?? 'https://kefiw.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${Astro.site?.toString() ?? 'https://kefiw.com'}?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};
---
<BaseLayout
  title="Kefiw — Fast, Free Word Tools, Converters & Calculators"
  description="Word unscramblers, anagram solvers, converters, calculators, and small games. Mobile-first, runs in your browser, no signup."
  canonical="/"
  keywords={['word tools', 'unscrambler', 'anagram solver', 'converters', 'calculators', 'scrabble']}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <aside class="border-b border-emerald-200 bg-gradient-to-r from-emerald-50 via-emerald-50 to-white">
    <div class="container-wide flex flex-col gap-3 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-emerald-600 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">New</span>
          <p class="text-sm font-semibold text-emerald-900">Kefiw introduces <span class="font-bold">Decisions</span></p>
        </div>
        <p class="mt-1 max-w-2xl text-sm text-emerald-900/80">
          Deterministic tools that model tradeoffs, runway, break-even points, and survival windows — no AI, just math you can trust.
        </p>
      </div>
      <a href="/decisions/" class="inline-flex shrink-0 items-center justify-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700">
        Explore Decisions →
      </a>
    </div>
  </aside>

  <section class="container-wide py-10 sm:py-14">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Small tools, big time saver.</h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600">
      Word unscramblers, converters, calculators, and lightweight games. Everything runs in your browser — no signup, no tracking, mobile-first.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      <a href="/word-tools/" class="btn-ghost">Word Tools</a>
      <a href="/converters/" class="btn-ghost">Converters</a>
      <a href="/calculators/" class="btn-ghost">Calculators</a>
      <a href="/decisions/" class="btn-ghost">Decisions</a>
      <a href="/games/" class="btn-ghost">Games</a>
    </div>
  </section>

  <PopularTools tools={popular} />

  <FeaturedClusters slugs={clusterSlugs} />

  <AdSlot slot="between-sections" />

  {(['word-tools','converters','calculators','games'] as const).map((cat) => (
    <section class="container-wide mt-10">
      <div class="flex items-baseline justify-between">
        <h2 class="text-xl font-semibold">{CATEGORIES[cat].title}</h2>
        <a href={`/${cat}/`} class="text-sm">See all →</a>
      </div>
      <p class="mt-1 text-sm text-slate-600">{CATEGORIES[cat].blurb}</p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {toolsByCategory(cat).slice(0, 6).map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  ))}
</BaseLayout>
