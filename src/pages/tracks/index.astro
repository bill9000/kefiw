---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { TRACK_GROUPS, TRACKS, trackHref } from '~/data/tracks';

const activeGroups = TRACK_GROUPS.filter((group) => group.tracks.length > 0);
---

<BaseLayout
  title="Tracks — Guided Calculator Pipelines | Kefiw"
  description="Kefiw Tracks turn related calculators, checklists, guides, and comparisons into guided decision plans with a final result page."
  canonical="/tracks/"
  keywords={['calculator tracks', 'guided calculator pipeline', 'decision support tools', 'roof replacement plan', 'freelance pricing plan']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/tracks/', label: 'Tracks' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Decision-support platform</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Tracks</h1>
      <p class="mt-3 text-lg text-slate-700">
        A Track is a guided pipeline, not a calculator directory. It takes a real goal and moves through calculators,
        checklists, guides, comparisons, and a next-step recommendation.
      </p>
    </header>

    <section class="mb-8 rounded-lg border border-slate-200 bg-slate-50 p-4">
      <h2 class="text-lg font-semibold text-slate-900">Track shape</h2>
      <ol class="mt-3 grid gap-2 text-sm text-slate-700 sm:grid-cols-3 lg:grid-cols-6">
        <li class="rounded-md bg-white p-3"><strong>Goal</strong><br />Name the decision.</li>
        <li class="rounded-md bg-white p-3"><strong>Calculators</strong><br />Collect the numbers.</li>
        <li class="rounded-md bg-white p-3"><strong>Checklist</strong><br />Catch missing inputs.</li>
        <li class="rounded-md bg-white p-3"><strong>Guide</strong><br />Explain the assumptions.</li>
        <li class="rounded-md bg-white p-3"><strong>Comparison</strong><br />Choose between paths.</li>
        <li class="rounded-md bg-white p-3"><strong>Next step</strong><br />Produce the plan.</li>
      </ol>
    </section>

    <section class="mb-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Recommended build order</h2>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        {TRACKS.map((track, index) => (
          <a
            href={trackHref(track)}
            class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm"
          >
            <div class="flex items-center justify-between gap-3">
              <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-700">{track.vertical}</span>
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-700">#{index + 1}</span>
            </div>
            <h3 class="mt-2 text-base font-semibold">{track.title}</h3>
            <p class="mt-1 text-sm text-slate-600">{track.resultTitle}</p>
          </a>
        ))}
      </div>
    </section>

    {activeGroups.map((group) => (
      <section id={group.id} class="scroll-mt-36 mt-8">
        <div class="mb-3 max-w-3xl">
          <h2 class="text-xl font-semibold text-slate-900">{group.label}</h2>
          <p class="mt-1 text-sm text-slate-600">{group.description}</p>
        </div>
        <div class="grid gap-4 lg:grid-cols-2">
          {group.tracks.map((track) => (
            <a
              href={trackHref(track)}
              class="block rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm"
            >
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-700">{track.vertical}</div>
              <h3 class="mt-1 text-xl font-semibold">{track.title}</h3>
              <p class="mt-1 text-sm text-slate-600">{track.goal}</p>
              <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-slate-600">
                <span class="rounded-full bg-slate-100 px-2.5 py-1">{track.duration}</span>
                <span class="rounded-full bg-slate-100 px-2.5 py-1">{track.steps.length} steps</span>
                <span class="rounded-full bg-slate-100 px-2.5 py-1">{track.reviewedBy[0]}</span>
              </div>
              <div class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-950">
                <strong>Final result page:</strong> {track.resultTitle}. {track.finalPlan.estimate}
              </div>
              <div class="mt-4 text-sm font-semibold text-brand-700">Open track</div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-8 rounded-lg border border-slate-200 bg-white p-4">
      <h2 class="text-lg font-semibold text-slate-900">Existing workflow primitives</h2>
      <p class="mt-1 text-sm text-slate-600">
        Chains, Scenarios, Comparisons, and curated clusters are the current building blocks. Tracks are the higher-level package that turns them into named plans.
      </p>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <a class="rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200" href="/chains/">Chains</a>
        <a class="rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200" href="/scenarios/">Scenarios</a>
        <a class="rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200" href="/comparisons/">Comparisons</a>
        <a class="rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200" href="/clusters/">Clusters</a>
      </div>
    </section>

    <ReviewMethodologyFooter approvalText="Tracks are reviewed by the relevant staff reviewers for each subject area." />
  </article>
</BaseLayout>
