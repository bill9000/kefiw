---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomelabBand from '~/components/homelab/HomelabBand.astro';
import EurocraftByline from '~/components/homelab/EurocraftByline.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { COST_ENGINE_UPDATED } from '~/lib/homelab/roof-cost-engine';
const title = 'Kefiw Property Improve — Honest home-improvement cost calculators';
const description = 'Roof, gutter, and skin-of-the-house cost calculators reviewed by a Texas-licensed general contractor. Range-based estimates, transparent methodology, no fake precision.';
---
<BaseLayout
  title={title}
  description={description}
  canonical="/homelab/"
  keywords={["home improvement cost", "roof cost calculator", "general contractor reviewed"]}
>
  <HomelabBand active="home" />
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/homelab/', label: 'Property Improve' }]} />
  <article class="container-wide py-6">
    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Kefiw Property Improve</h1>
      <p class="mt-2 max-w-3xl text-slate-700">
        Honest home-improvement cost calculators reviewed by a working Texas-licensed general contractor.
        Range-based estimates, transparent methodology, no fake precision — built so a homeowner can sanity-check a roofer's bid.
      </p>
    </header>

    <EurocraftByline updated={COST_ENGINE_UPDATED} compact={false} />

    <section aria-label="Cost calculators" class="mt-6">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Cost calculators</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/homelab/roof-replacement-cost-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Main calculator</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Roof Replacement Cost Calculator</div>
          <p class="mt-1 text-sm text-slate-600">12 inputs → low/typical/high range, $/sqft, material/labor split, financing, and questions to ask each roofer.</p>
        </a>
        <a href="/homelab/asphalt-shingle-cost-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Material — asphalt</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Asphalt Shingle Cost Calculator</div>
          <p class="mt-1 text-sm text-slate-600">3-tab vs architectural vs designer asphalt — cost difference on the same roof.</p>
        </a>
        <a href="/homelab/metal-roof-cost-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Material — metal</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Metal Roof Cost Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Standing seam vs exposed-fastener corrugated. Lifecycle math vs asphalt.</p>
        </a>
        <a href="/homelab/new-roof-roi-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Resale</div>
          <div class="mt-1 text-base font-semibold text-slate-900">New Roof ROI Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Estimated resale uplift by sale horizon and market condition.</p>
        </a>
      </div>
    </section>

    <section aria-label="Insurance & claims" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Insurance &amp; claims</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/homelab/roof-insurance-deductible-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Out-of-pocket</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Roof Insurance Deductible Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Flat or % deductible, RCV / ACV path, depreciation hold-back, code upgrades — what you actually pay.</p>
        </a>
        <a href="/homelab/acv-vs-rcv-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Depreciation</div>
          <div class="mt-1 text-base font-semibold text-slate-900">ACV vs RCV Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Depreciation gap on your specific roof. The most important line on your declarations page.</p>
        </a>
        <a href="/homelab/hail-damage-severity-estimator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Claim outcome</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Hail Damage Severity Estimator</div>
          <p class="mt-1 text-sm text-slate-600">Will the claim approve full-scope, partial, or get denied? What adjusters look for.</p>
        </a>
        <a href="/homelab/roof-repair-vs-replacement-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Decision tool</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Roof Repair vs Replacement</div>
          <p class="mt-1 text-sm text-slate-600">Patch the damage or replace the whole roof? Weighs age, damage, leaks, sale horizon, insurance.</p>
        </a>
      </div>
    </section>

    <section aria-label="Measurement & materials" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Measurement &amp; materials</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/homelab/roof-square-footage-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Measurement</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Roof Square Footage Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Roof surface area from home sqft + pitch, footprint + pitch, or direct ridge × eave.</p>
        </a>
        <a href="/homelab/roof-pitch-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Geometry</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Roof Pitch Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Rise:run ↔ degrees ↔ slope %. Area multiplier and walkability category.</p>
        </a>
        <a href="/homelab/shingle-bundle-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Materials</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Shingle Bundle Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Field, ridge cap, and starter strip — the three counts that get under-ordered.</p>
        </a>
        <a href="/homelab/methodology/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Reference</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Methodology</div>
          <p class="mt-1 text-sm text-slate-600">How estimates are calculated, what's included and excluded.</p>
        </a>
      </div>
    </section>

    <section aria-label="Spec helpers" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Spec helpers</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/homelab/underlayment-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Spec</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Underlayment Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Synthetic vs 15# / 30# felt — rolls and cost.</p>
        </a>
        <a href="/homelab/ice-water-shield-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Spec</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Ice &amp; Water Shield Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Eaves + valleys + low-slope + penetrations coverage.</p>
        </a>
        <a href="/homelab/drip-edge-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Spec</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Drip Edge Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Eave + rake linear feet, 10-foot piece count, cost.</p>
        </a>
        <a href="/homelab/attic-ventilation-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Spec</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Attic Ventilation Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Required NFA, ridge / soffit / box-vent quantities.</p>
        </a>
        <a href="/homelab/decking-replacement-calculator/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Spec</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Decking Replacement Calculator</div>
          <p class="mt-1 text-sm text-slate-600">Sheets + cost (OSB or plywood) by replacement %.</p>
        </a>
      </div>
    </section>

    <section aria-label="City pages" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">By city</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/homelab/houston-roof-replacement-cost/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Texas — home market</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Houston</div>
          <p class="mt-1 text-sm text-slate-600">Hail belt, hurricane-edge, heat-aged shingles. $11K–$22K typical.</p>
        </a>
        <a href="/homelab/dallas-roof-replacement-cost/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Texas</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Dallas / DFW</div>
          <p class="mt-1 text-sm text-slate-600">Worst hail belt in the US — Class 4 default, percentage deductibles standard.</p>
        </a>
        <a href="/homelab/austin-roof-replacement-cost/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Texas</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Austin</div>
          <p class="mt-1 text-sm text-slate-600">UV-driven aging, Hill Country terrain, WUI fire considerations.</p>
        </a>
        <a href="/homelab/san-antonio-roof-replacement-cost/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Texas</div>
          <div class="mt-1 text-base font-semibold text-slate-900">San Antonio</div>
          <p class="mt-1 text-sm text-slate-600">Lower labor rates, historic district overlays, tile prevalence.</p>
        </a>
        <a href="/homelab/atlanta-roof-replacement-cost/" class="block rounded-md border border-slate-200 bg-white p-4 transition hover:border-amber-500 hover:shadow-sm">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Georgia</div>
          <div class="mt-1 text-base font-semibold text-slate-900">Atlanta</div>
          <p class="mt-1 text-sm text-slate-600">Steep-pitch Colonials, humidity-driven decking issues, algae-resistant shingle defaults.</p>
        </a>
      </div>
    </section>

    <section aria-label="Property Improve expansion roadmap" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Expansion roadmap</h2>
      <p class="mb-4 max-w-3xl text-sm text-slate-600">
        Roof is the first reviewed Property Improve cluster. The commercial home-improvement clusters below are approved as the structure for navigation, guides, and calculator pages.
      </p>
      <div class="grid gap-4 md:grid-cols-2">
        <section id="hvac" class="scroll-mt-24 rounded-md border border-slate-200 bg-white p-4">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Next cluster</div>
          <h3 class="mt-1 text-base font-semibold text-slate-900">HVAC</h3>
          <p class="mt-1 text-sm text-slate-600">HVAC replacement cost, AC replacement, furnace replacement, heat pump cost, ductwork cost, and repair-vs-replace logic.</p>
        </section>
        <section id="remodel" class="scroll-mt-24 rounded-md border border-slate-200 bg-white p-4">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Major contractor vertical</div>
          <h3 class="mt-1 text-base font-semibold text-slate-900">Remodel</h3>
          <p class="mt-1 text-sm text-slate-600">Kitchen remodel, bathroom remodel, basement remodel, flooring, painting, siding, deck and patio calculators.</p>
        </section>
        <section id="windows" class="scroll-mt-24 rounded-md border border-slate-200 bg-white p-4">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Envelope</div>
          <h3 class="mt-1 text-base font-semibold text-slate-900">Windows &amp; Doors</h3>
          <p class="mt-1 text-sm text-slate-600">Window replacement cost, door replacement cost, and window ROI calculators.</p>
        </section>
        <section id="solar" class="scroll-mt-24 rounded-md border border-slate-200 bg-white p-4">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Energy investment</div>
          <h3 class="mt-1 text-base font-semibold text-slate-900">Solar</h3>
          <p class="mt-1 text-sm text-slate-600">Solar savings, solar payback, battery backup cost, and utility-bill offset calculators.</p>
        </section>
        <section id="energy" class="scroll-mt-24 rounded-md border border-slate-200 bg-white p-4 md:col-span-2">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">Operating cost</div>
          <h3 class="mt-1 text-base font-semibold text-slate-900">Energy</h3>
          <p class="mt-1 text-sm text-slate-600">Insulation savings, appliance savings, energy savings, ventilation, and attic-efficiency calculators.</p>
        </section>
      </div>
    </section>

    <section aria-label="Coming next" class="mt-8">
      <h2 class="mb-3 text-xl font-semibold text-slate-900">Coming next</h2>
      <ul class="grid gap-2 text-sm text-slate-700 md:grid-cols-2">
        <li class="rounded-md border border-slate-200 bg-slate-50 p-3">Tile Roof Cost Calculator</li>
        <li class="rounded-md border border-slate-200 bg-slate-50 p-3">Cost city: Tampa / Orlando</li>
        <li class="rounded-md border border-slate-200 bg-slate-50 p-3">Cost city: Miami (HVHZ)</li>
        <li class="rounded-md border border-slate-200 bg-slate-50 p-3">Cost city: Charlotte / Nashville</li>
        <li class="rounded-md border border-slate-200 bg-slate-50 p-3">Skin-of-house: gutters, siding, soffit / fascia</li>
      </ul>
    </section>

    <section aria-label="Why us" class="mt-8 rounded-md border border-slate-200 bg-white p-4">
      <h2 class="mb-2 text-xl font-semibold text-slate-900">Why this differs from generic cost calculators</h2>
      <ul class="space-y-2 text-sm text-slate-700">
        <li><strong>Reviewed by a working contractor</strong>, not aggregated AI rewrites. Eurocraft is a Texas-licensed general contractor with hands-on insurance-claim experience.</li>
        <li><strong>Range-based outputs.</strong> A bid in a single dollar number is wrong by definition. Our typical range is where a properly-scoped quote usually lands.</li>
        <li><strong>Decking surprise is modeled.</strong> Most calculators ignore the rotted decking that's only found after tear-off — we surface it as a risk-weighted line.</li>
        <li><strong>No lead-gen forms, no contractor matching, no tracked phone numbers.</strong> Just the calculator and the math.</li>
      </ul>
    </section>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
    />
  </article>
</BaseLayout>
