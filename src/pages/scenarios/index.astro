---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
---
<BaseLayout
  title="Scenarios — Parallel Stress-Test | Kefiw"
  description="Run the same forecast under Baseline, Optimized, and Crisis assumptions at the same time. The triad primitive reveals how far apart one decision can drift."
  canonical="/scenarios/"
  keywords={['scenario calculator', 'stress test parallel', 'baseline optimized crisis', 'triad decision tool']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/scenarios/', label: 'Scenarios' }]} />
  <article class="container-wide py-6">
    <header class="mb-8 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600">The Triad Primitive</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">Scenarios</h1>
      <p class="mt-3 text-lg text-slate-700">
        Three parallel instances of the same tool, pre-seeded with different assumptions. Three pillars,
        one forecast shape — so you can see the spread in a glance instead of clicking back and forth.
      </p>
    </header>

    <section class="grid gap-4 sm:grid-cols-2">
      <a
        href="/scenarios/stress-test-triad/"
        class="block rounded-lg border border-cyan-200 bg-white p-5 transition hover:border-cyan-500 hover:bg-cyan-50"
      >
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">RUNWAY · TRIAD</div>
        <div class="mt-1 text-lg font-semibold text-slate-900">Baseline · Optimized · Crisis</div>
        <p class="mt-2 text-sm text-slate-600">
          Three Runway Zero columns running in parallel. Current trajectory, optimized trajectory,
          revenue-zero crisis. Pre-seeded, persistent.
        </p>
        <div class="mt-3 text-xs text-slate-500">3 pillars · namespaced state · ~1 min to explore</div>
      </a>

      <a
        href="/scenarios/focus-triad/"
        class="block rounded-lg border border-cyan-200 bg-white p-5 transition hover:border-cyan-500 hover:bg-cyan-50"
      >
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">FOCUS · TRIAD</div>
        <div class="mt-1 text-lg font-semibold text-slate-900">Distracted · Typical · Deep</div>
        <p class="mt-2 text-sm text-slate-600">
          Three Task Switching Tax columns — 8 contexts, 3 contexts, single-threaded. Pre-seeded, persistent.
        </p>
        <div class="mt-3 text-xs text-slate-500">3 pillars · namespaced state · ~1 min to explore</div>
      </a>

      <a
        href="/scenarios/rate-triad/"
        class="block rounded-lg border border-cyan-200 bg-white p-5 transition hover:border-cyan-500 hover:bg-cyan-50"
      >
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">RATE · TRIAD</div>
        <div class="mt-1 text-lg font-semibold text-slate-900">Conservative · Realistic · Aggressive</div>
        <p class="mt-2 text-sm text-slate-600">
          Three Minimum Viable Rate columns at 45% / 60% / 75% utilization. Same target need, different hourly answer.
        </p>
        <div class="mt-3 text-xs text-slate-500">3 pillars · namespaced state · ~1 min to explore</div>
      </a>
    </section>

    <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="text-lg font-semibold text-slate-900">How the triad primitive works</h2>
      <p class="mt-2 text-sm text-slate-700">
        Each pillar is a namespaced tool instance. On first visit the triad writes pre-seeded state into
        separate localStorage keys
        (<code class="rounded bg-white px-1 text-xs text-slate-800">tool__baseline</code>,
        <code class="rounded bg-white px-1 text-xs text-slate-800">__optimized</code>,
        <code class="rounded bg-white px-1 text-xs text-slate-800">__crisis</code>). After that, every
        edit persists per-pillar.
      </p>
    </section>
  </article>
</BaseLayout>
