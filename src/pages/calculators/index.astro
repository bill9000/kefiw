---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ToolCard from '~/components/ToolCard.astro';
import { CATEGORIES, toolsByCategory } from '~/data/tools';
const cat = CATEGORIES.calculators;
const tools = toolsByCategory('calculators');
---
<BaseLayout
  title="Calculators — Percentage, Age, Date Difference | Kefiw"
  description="Everyday calculators: percentage, age, and date difference. Mobile-friendly, client-side."
  canonical="/calculators/"
  keywords={['calculators', 'percentage calculator', 'age calculator', 'date difference']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/calculators/', label: cat.title }]} />
  <header class="container-wide py-6">
    <h1 class="text-3xl font-bold tracking-tight">Calculators</h1>
    <p class="mt-2 max-w-2xl text-slate-600">{cat.blurb}</p>
  </header>
  <section class="container-wide">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>
</BaseLayout>
