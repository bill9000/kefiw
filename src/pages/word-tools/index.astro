---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ToolCard from '~/components/ToolCard.astro';
import { CATEGORIES, toolsByCategory } from '~/data/tools';
const cat = CATEGORIES['word-tools'];
const tools = toolsByCategory('word-tools');
---
<BaseLayout
  title="Word Tools — Unscramblers, Anagrams, Scrabble Helpers | Kefiw"
  description="Every word tool you need: unscrambler, anagram solver, Scrabble and Words With Friends helpers, word counters, and more."
  canonical="/word-tools/"
  keywords={['word tools', 'unscrambler', 'anagram solver', 'word finder', 'scrabble', 'word counter']}
>
  <Breadcrumb crumbs={[{ href: '/', label: 'Home' }, { href: '/word-tools/', label: cat.title }]} />
  <header class="container-wide py-6">
    <h1 class="text-3xl font-bold tracking-tight">Word Tools</h1>
    <p class="mt-2 max-w-2xl text-slate-600">{cat.blurb}</p>
  </header>
  <section class="container-wide">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>
</BaseLayout>
