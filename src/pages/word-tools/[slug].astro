---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import FAQ from '~/components/FAQ.astro';
import { buildSeoPages, buildFaq, relatedSlugs, type SeoPage } from '~/lib/seo-pages';

export async function getStaticPaths() {
  const { pages } = buildSeoPages();
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props { page: SeoPage; }
const { page } = Astro.props;

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/word-tools/', label: 'Word Tools' },
  { href: `/word-tools/${page.slug}/`, label: page.h1 },
];

const faq = buildFaq(page);
const related = relatedSlugs(page);
const canonical = `/word-tools/${page.slug}/`;

const introLead =
  page.family === 'prefix' && page.length != null
    ? `There are ${page.count.toLocaleString()} ${page.length}-letter words starting with the letter ${page.letter.toUpperCase()} in the Kefiw fast word list. Common examples include ${page.examples.join(', ')}. The complete alphabetical list is below.`
    : page.family === 'suffix' && page.length != null
    ? `There are ${page.count.toLocaleString()} ${page.length}-letter words ending in the letter ${page.letter.toUpperCase()} in the Kefiw fast word list. Early entries include ${page.examples.join(', ')}. The complete alphabetical list is below.`
    : `${page.count.toLocaleString()} English words end with the letters "${page.letter}". Short examples include ${page.examples.join(', ')}. The longest match in this list is ${page.longest}.`;

const interactiveHref =
  page.family === 'prefix' ? '/word-tools/words-starting-with/' : '/word-tools/words-ending-with/';
const interactiveLabel =
  page.family === 'prefix' ? 'Words Starting With (interactive)' : 'Words Ending With (interactive)';

const wordsByLength: Record<number, string[]> = {};
if (page.family === 'curated-suffix') {
  for (const w of page.words) {
    (wordsByLength[w.length] ??= []).push(w);
  }
}
const wordLengths = Object.keys(wordsByLength).map(Number).sort((a, b) => a - b);

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: page.h1,
  numberOfItems: page.count,
  itemListElement: page.examples.map((w, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: w,
  })),
};
---
<BaseLayout
  title={page.title}
  description={page.metaDescription}
  canonical={canonical}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(itemListJsonLd)} />
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      <p class="mt-2 max-w-3xl text-slate-600">{introLead}</p>
    </header>

    <section aria-label="Quick actions" class="mb-6 flex flex-wrap gap-2">
      <a href={interactiveHref} class="btn-primary">Open in {interactiveLabel}</a>
      <a href="/word-tools/word-finder/" class="btn-ghost">Word Finder</a>
      <a href="/word-tools/scrabble-helper/" class="btn-ghost">Scrabble Helper</a>
    </section>

    <section aria-label="Word list" class="mb-10">
      <h2 class="mb-3 text-xl font-semibold">All {page.count.toLocaleString()} words</h2>
      {page.family === 'curated-suffix' ? (
        <div class="space-y-4">
          {wordLengths.map((n) => (
            <details class="rounded-md border border-slate-200 bg-white p-3" open={n <= 6}>
              <summary class="cursor-pointer text-sm font-semibold text-slate-700">
                {n}-letter words ({wordsByLength[n].length.toLocaleString()})
              </summary>
              <ul class="mt-2 flex flex-wrap gap-1.5 font-mono text-sm">
                {wordsByLength[n].map((w) => (
                  <li class="chip">{w}</li>
                ))}
              </ul>
            </details>
          ))}
        </div>
      ) : (
        <ul class="flex flex-wrap gap-1.5 font-mono text-sm">
          {page.words.map((w) => (
            <li class="chip">{w}</li>
          ))}
        </ul>
      )}
    </section>

    <section class="prose-tool max-w-3xl">
      <h2>About this list</h2>
      <p>
        This list is drawn from the public-domain ENABLE1 word list, which covers the majority of
        standard English Scrabble- and Words With Friends-legal plays. A small fraction of entries
        may be judged differently by tournament dictionaries like TWL or SOWPODS — when in doubt,
        confirm with the interactive helper below.
      </p>
      <p>
        Want a different length, a different letter, or a custom pattern? The{' '}
        <a href="/word-tools/word-finder/">Word Finder</a> supports pattern mode with
        <code>?</code> wildcards (for example, <code>c?t</code>).
      </p>
    </section>

    {related.length > 0 && (
      <section aria-label="Related lists" class="container-wide mt-10">
        <h2 class="mb-3 text-xl font-semibold">Related lists</h2>
        <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
          {related.map((link) => (
            <li>
              <a href={link.href} class="block rounded-md border border-slate-200 p-3 text-sm hover:border-brand-500 hover:bg-brand-50">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <FAQ items={faq} />
  </article>
</BaseLayout>
