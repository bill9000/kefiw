---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import CareCategoryCard from '~/components/CareCategoryCard.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { CARE_CATEGORIES, careCategoryHref, type CareCategoryPage } from '~/data/care-categories';

interface Props {
  category: CareCategoryPage;
}

const { category } = Astro.props;
---

<BaseLayout
  title={category.title}
  description={category.description}
  canonical={careCategoryHref(category.slug)}
  keywords={category.keywords}
>
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: '/care/', label: 'Care' },
    { href: careCategoryHref(category.slug), label: category.label },
  ]} />

  <article class="container-wide py-6">
    <header class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Care Hub</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{category.h1}</h1>
      <p class="mt-3 text-lg leading-7 text-slate-700">{category.intro}</p>
      <p class="mt-3 max-w-3xl rounded-md border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm leading-6 text-cyan-950">
        Kefiw tools organize care decisions, estimate costs, and prepare better questions. They do not replace medical, legal, financial, benefits, or insurance advice.
      </p>
      {(category.primaryCta || category.secondaryCta) && (
        <div class="mt-5 flex flex-wrap gap-3">
          {category.primaryCta && (
            <a class="rounded-md bg-brand-700 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800" href={category.primaryCta.href}>
              {category.primaryCta.title}
            </a>
          )}
          {category.secondaryCta && (
            <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 no-underline hover:border-brand-400" href={category.secondaryCta.href}>
              {category.secondaryCta.title}
            </a>
          )}
        </div>
      )}
    </header>

    <section class="mt-8">
      <h2 class="text-xl font-semibold text-slate-900">Tools in this section</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {category.cards.map((card) => <CareCategoryCard card={card} />)}
      </div>
    </section>

    <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="space-y-8">
        {category.sections.map((section) => (
          <section class="border-t border-slate-200 pt-6">
            <h2 class="text-xl font-semibold text-slate-900">{section.title}</h2>
            <p class="mt-2 max-w-3xl leading-7 text-slate-700">{section.body}</p>
            {section.bullets && (
              <ul class="mt-3 max-w-3xl list-disc space-y-1 pl-5 text-sm leading-6 text-slate-700">
                {section.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}
            {section.cards && (
              <div class="mt-4 grid gap-3 md:grid-cols-2">
                {section.cards.map((card) => <CareCategoryCard card={card} />)}
              </div>
            )}
          </section>
        ))}
      </div>

      <aside class="h-fit rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Care Navigation</h2>
        <nav class="mt-3 space-y-2 text-sm">
          {CARE_CATEGORIES.map((item) => (
            <a
              href={careCategoryHref(item.slug)}
              class={`block rounded-md px-3 py-2 no-underline ${item.slug === category.slug ? 'bg-brand-50 font-semibold text-brand-800' : 'text-slate-700 hover:bg-slate-50'}`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>
    </div>

    <ReviewMethodologyFooter
      reviewerLinks={[
        { label: 'registered nurse', href: '/registered-nurse-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]}
      includeHealthDisclaimer
    />
  </article>
</BaseLayout>
