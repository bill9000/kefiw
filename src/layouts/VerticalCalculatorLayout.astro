---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import DecisionCalculator from '~/components/vertical/DecisionCalculator';
import { verticalCalculatorHref, verticalLabel, type BusinessRiskProfile, type VerticalCalculatorPage } from '~/data/vertical-calculators';

interface Props {
  page: VerticalCalculatorPage;
}

const { page } = Astro.props;
const areaLabel = verticalLabel(page.area);
const canonical = verticalCalculatorHref(page);
const reviewerLinks =
  page.area === 'property'
    ? [
        { label: 'realtor', href: '/realtor-review/' },
        { label: 'remodeling contractor', href: '/remodeling-contractor-review/' },
        { label: 'engineering', href: '/engineering-review/' },
        { label: 'scientific reviewer', href: '/scientific-review/' },
      ]
    : page.area === 'care'
      ? [
          { label: 'registered nurse', href: '/registered-nurse-review/' },
          { label: 'scientific reviewer', href: '/scientific-review/' },
        ]
      : [
          { label: 'engineering', href: '/engineering-review/' },
          { label: 'scientific reviewer', href: '/scientific-review/' },
        ];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: page.h1,
  description: page.description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  url: new URL(canonical, Astro.site).toString(),
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const highRiskCopy: Record<BusinessRiskProfile, string[]> = {
  'federal-tax': [
    'This calculator estimates federal tax planning reserves using educational assumptions. It does not file taxes or guarantee that penalties are avoided.',
    'State tax, local tax, credits, deductions, withholding, uneven income, and filing status can change the result.',
  ],
  'deduction-risk': [
    'This checker flags expenses that may need stronger documentation, clearer business-use allocation, capitalization review, or a more conservative treatment.',
    'It does not determine that an expense is deductible or safe.',
  ],
  's-corp': [
    'This tool estimates possible savings after reasonable-salary, payroll, filing, state, and admin assumptions.',
    'It does not determine a reasonable salary, tax filing position, or whether S-corp treatment is right for a specific taxpayer.',
  ],
  payroll: [
    'This calculator estimates federal payroll burden before state payroll taxes, benefits, insurance, PTO, equipment, software, recruiting, training, and management time.',
    'It is a planning tool, not a payroll filing system.',
  ],
  'worker-classification': [
    'This tool compares estimated cost and operating tradeoffs. It does not determine whether a worker is legally an employee or independent contractor.',
    'Worker classification depends on federal tax rules, labor rules, state rules, and the facts of the relationship.',
  ],
  'cloud-saas': [
    'Cloud and SaaS pricing can change by vendor, product, region, usage, commitment, contract term, support plan, renewal, data transfer, and cancellation rule.',
    'This calculator is a planning model and does not fully predict a provider bill or vendor contract outcome.',
  ],
};

const highRiskNotes = page.riskProfile ? highRiskCopy[page.riskProfile] : [];
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonical={canonical}
  keywords={page.keywords}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <Breadcrumb crumbs={[
    { href: '/', label: 'Home' },
    { href: `/${page.area}/`, label: areaLabel },
    { href: canonical, label: page.h1 },
  ]} />

  <article class="container-wide py-6">
    <header class="mb-6 max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{areaLabel} · {page.group}</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{page.h1}</h1>
      {page.tagline && <p class="mt-2 text-base font-semibold text-brand-800">{page.tagline}</p>}
      <p class="mt-3 text-lg text-slate-700">{page.summary}</p>
      <p class="mt-2 max-w-3xl text-slate-600">{page.promise ?? page.description}</p>
      {page.bestFor && (
        <p class="mt-3 max-w-3xl rounded-md border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700">
          <span class="font-semibold text-slate-900">Best for:</span> {page.bestFor}
        </p>
      )}
    </header>

    <section id="tool-start" class="scroll-mt-32">
      <DecisionCalculator client:load page={page} />
    </section>

    {page.assumptions.length > 0 && (
      <section class="mt-6 max-w-4xl rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Assumptions</h2>
        <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
          {page.assumptions.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}

    <section class="prose-tool mt-8 max-w-3xl">
      {page.sections.map((section) => (
        <>
          <h2>{section.title}</h2>
          <p>{section.body}</p>
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </>
      ))}
    </section>

    {page.related.length > 0 && (
      <section class="mt-8 max-w-4xl">
        <h2 class="mb-3 text-lg font-semibold text-slate-900">Related tools and tracks</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {page.related.map((item) => (
            <a href={item.href} class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900 no-underline transition hover:border-brand-400 hover:shadow-sm">
              <div class="text-sm font-semibold">{item.label}</div>
              {item.note && <div class="mt-1 text-xs text-slate-600">{item.note}</div>}
            </a>
          ))}
        </div>
      </section>
    )}

    {page.monetizationFit && page.monetizationFit.length > 0 && (
      <section class="mt-8 max-w-4xl rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-slate-900">Tools that may help after you run the numbers</h2>
        <p class="mt-1 text-sm text-slate-600">
          Use this only after the calculator shows where the pressure is. The useful category depends on the bottleneck, not the ad pitch.
        </p>
        <ul class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
          {page.monetizationFit.map((item) => (
            <li class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-slate-700">{item}</li>
          ))}
        </ul>
      </section>
    )}

    {page.sources.length > 0 && (
      <section class="mt-8 max-w-4xl rounded-lg border border-slate-200 bg-slate-50 p-4">
        <h2 class="text-lg font-semibold text-slate-900">Source links used for this calculator family</h2>
        <ul class="mt-2 grid gap-2 text-sm sm:grid-cols-2">
          {page.sources.map((source) => (
            <li>
              <a class="text-brand-700 hover:underline" href={source.href}>{source.label}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {page.riskProfile && (
      <section class="mt-8 max-w-4xl rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-950">
        <h2 class="text-lg font-semibold">Source check and limits</h2>
        {page.sourceCheckedAt && <p class="mt-2"><strong>Last source check:</strong> {page.sourceCheckedAt}</p>}
        {page.sourceScope && <p class="mt-1"><strong>Scope checked:</strong> {page.sourceScope}</p>}
        <ul class="mt-3 list-disc space-y-1 pl-5">
          {highRiskNotes.map((note) => <li>{note}</li>)}
        </ul>
        <p class="mt-3">
          Kefiw shows the assumptions used so you can audit the math before relying on the result. This tool does not provide legal, tax,
          payroll, accounting, compliance, or provider-specific pricing advice.
        </p>
      </section>
    )}

    <ReviewMethodologyFooter reviewerLinks={reviewerLinks} includeHealthDisclaimer={page.healthDisclaimer} />
  </article>
</BaseLayout>
