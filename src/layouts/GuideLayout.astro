---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import FAQ from '~/components/FAQ.astro';
import AdSlot from '~/components/ads/AdSlot.tsx';
import InlineMetric from '~/components/InlineMetric.astro';
import PivotSwitch from '~/components/PivotSwitch.tsx';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { reviewPanelForArea } from '~/data/review';
import type { ContentPageConfig } from '~/data/content-pages';
import { CATEGORY_LABEL, contentPageById, contentHref } from '~/data/content-pages';
import { TOOLS_BY_ID, toolHref } from '~/data/tools';
import { CLUSTERS_BY_SLUG, clusterHref } from '~/data/clusters';
import { renderMarkdown } from '~/lib/markdown';

// Build-time lookup: which /og/{slug}-social.png files actually exist in
// public/og/? Cached once per build. When an article has a discoverHeadline
// but no matching image, we fall back to the site-wide /og-image.png
// instead of emitting a broken meta tag.
const OG_SOCIAL_DIR = path.join(process.cwd(), 'public', 'og');
let OG_SOCIAL_SET: Set<string> | null = null;
function hasOgSocial(slug: string): boolean {
  if (OG_SOCIAL_SET === null) {
    try {
      OG_SOCIAL_SET = new Set(
        fs.readdirSync(OG_SOCIAL_DIR).filter((f) => f.endsWith('-social.png'))
      );
    } catch {
      OG_SOCIAL_SET = new Set();
    }
  }
  return OG_SOCIAL_SET.has(`${slug}-social.png`);
}

function hasPublicAsset(publicPath?: string): boolean {
  if (!publicPath) return false;
  const normalized = publicPath.replace(/^\/+/, '');
  if (!normalized || normalized.includes('..')) return false;
  return fs.existsSync(path.join(process.cwd(), 'public', normalized));
}

interface Props {
  config: ContentPageConfig;
}

const { config } = Astro.props;
const canonical = `/guides/${config.slug}/`;

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/guides/', label: 'Guides' },
  { href: canonical, label: config.h1 },
];

// Resolve "when to use which tool / article" — each entry becomes a rich card.
interface ResolvedWhenToUse { href: string; label: string; note: string; sub?: string; }
const whenToUseResolved: ResolvedWhenToUse[] = (config.whenToUse ?? [])
  .map((item): ResolvedWhenToUse | null => {
    if (item.toolId) {
      const tool = TOOLS_BY_ID[item.toolId];
      if (!tool || tool.comingSoon) return null;
      return { href: toolHref(tool), label: tool.h1, note: item.note, sub: tool.description };
    }
    if (item.articleId) {
      const page = contentPageById(item.articleId);
      if (!page) return null;
      return { href: contentHref(page), label: page.h1, note: item.note, sub: page.subhead };
    }
    return null;
  })
  .filter((x): x is ResolvedWhenToUse => !!x);

// Related — union of explicit relatedLinks + relatedIds (tools or content pages).
interface ResolvedLink { href: string; label: string; sub?: string; }
const resolvedFromIds: ResolvedLink[] = (config.relatedIds ?? []).flatMap((id) => {
  const tool = TOOLS_BY_ID[id];
  if (tool && !tool.comingSoon) return [{ href: toolHref(tool), label: tool.h1, sub: tool.description }];
  const page = contentPageById(id);
  if (page) return [{ href: contentHref(page), label: page.h1, sub: page.subhead }];
  return [];
});
const allRelated: ResolvedLink[] = [
  ...(config.relatedLinks ?? []).map((r) => ({ href: r.href, label: r.label })),
  ...resolvedFromIds,
];

const cluster = config.clusterId ? CLUSTERS_BY_SLUG[config.clusterId] : undefined;
const guideRelatedToolCategories = (config.relatedIds ?? []).flatMap((id) => {
  const category = TOOLS_BY_ID[id]?.category;
  return category ? [category] : [];
});
const guideReviewArea = cluster?.section === 'health'
  ? 'health-guide'
  : cluster?.section ?? guideRelatedToolCategories[0];
const reviewConfig = reviewPanelForArea(guideReviewArea);
const usesHealthReview = reviewConfig.reviewers.some((reviewer) => reviewer.href === '/registered-nurse-review/');
const reviewApprovalLinks = usesHealthReview
  ? [
      { label: 'registered nurse', href: '/registered-nurse-review/' },
      { label: 'scientific reviewer', href: '/scientific-review/' },
    ]
  : undefined;

const hasFaq = (config.faq ?? []).length > 0;
const hasThresholds = !!config.thresholds;
const pivotTool = config.pivotLink ? TOOLS_BY_ID[config.pivotLink.toolId] : undefined;
const hasPivot = !!(config.pivotLink && pivotTool && !pivotTool.comingSoon);
const secondaryCtas = config.secondaryCtas ?? [];
const showCtaRow = !!config.primaryCta || secondaryCtas.length > 0;
const hasLongform = !!config.longformMarkdown && config.longformMarkdown.trim().length > 0;
const longformHtml = hasLongform ? renderMarkdown(config.longformMarkdown!) : '';
const hasBody = !hasLongform && !!config.bodyHtml;
const hasKeyPoints = (config.keyPoints ?? []).length > 0;
const hasExamples = (config.examples ?? []).length > 0;
const hasHowTo = (config.howTo ?? []).length > 0;
const hasWhenToUse = whenToUseResolved.length > 0;

// SOP tone — industrial brutalist shell
const isSop = config.toneProfile === 'sop';
const lmSpecs = config.liveMetrics ?? [];
const hasFormula = !!config.formulaAnchor;
const hasGates = (config.logicalGates ?? []).length > 0;

// PivotSwitch targets (resolved to tools; falls back to static pivotLink if unset)
function resolvePivotTarget(t?: { toolId: string; note: string }) {
  if (!t) return null;
  const tool = TOOLS_BY_ID[t.toolId];
  if (!tool || tool.comingSoon) return null;
  return { href: toolHref(tool), label: tool.h1, note: t.note };
}
const pvCritical = resolvePivotTarget(config.pivotSwitch?.critical);
const pvStable = resolvePivotTarget(config.pivotSwitch?.stable);
const pvFallback = resolvePivotTarget(config.pivotSwitch?.fallback);
const hasPivotSwitch = !!(pvCritical && pvStable && pvFallback);

// Substantial articles (discoverHeadline set) use the linked social image when
// one was shipped. Slug-based lookup remains as the fallback convention.
// Otherwise the site-wide /og-image.png falls through from BaseLayout's default.
// Explicit config.ogImage always wins.
const imageAssetHeroImage = config.imageAsset?.image && hasPublicAsset(config.imageAsset.image)
  ? config.imageAsset.image
  : undefined;
const imageAssetOgImage = config.imageAsset?.socialImage && hasPublicAsset(config.imageAsset.socialImage)
  ? config.imageAsset.socialImage
  : undefined;
const defaultOgImage = imageAssetOgImage ?? (config.discoverHeadline && hasOgSocial(config.slug)
  ? `/og/${config.slug}-social.png`
  : undefined);
const resolvedOgImage = config.ogImage ?? defaultOgImage;
const resolvedHeroImage = imageAssetHeroImage ?? imageAssetOgImage;
const resolvedImageAlt = config.discoverHeadline ?? `${config.h1} guide image`;

const siteUrl = Astro.site ?? new URL('https://kefiw.com');
const canonicalUrl = new URL(canonical, siteUrl).toString();
const resolvedOgImageUrl = resolvedOgImage ? new URL(resolvedOgImage, siteUrl).toString() : undefined;

function firstSentence(text?: string): string | undefined {
  const cleaned = text?.replace(/\s+/g, ' ').trim();
  if (!cleaned) return undefined;
  return (cleaned.match(/^(.+?[.!?])(\s|$)/)?.[1] ?? cleaned).trim();
}

function sectionLimit(): string {
  switch (config.section) {
    case 'health':
      return 'Use this as educational planning context only, not a diagnosis, treatment plan, or substitute for a qualified clinician.';
    case 'calculators':
    case 'converters':
      return 'The result is only as good as the inputs, units, assumptions, and rounding you choose.';
    case 'games':
      return 'Use the helper to learn patterns or keep play moving; hide answers when you want the full challenge.';
    case 'word-tools':
      return 'Use suggestions to reduce friction, then choose the word that still fits meaning, tone, and rules.';
    case 'logic':
      return 'Use the framework to structure judgment, then verify constraints, costs, and risks before acting.';
    default:
      return 'Treat this as a practical aid for the task, not a replacement for professional judgment.';
  }
}

const quickAnswerText = config.outcomeLine ?? firstSentence(config.description) ?? firstSentence(config.intro);
const quickIntentText = config.subhead ?? firstSentence(config.intro);
const bestNextStep = config.primaryCta
  ? { href: config.primaryCta.href, label: config.primaryCta.label }
  : whenToUseResolved[0]
    ? { href: whenToUseResolved[0].href, label: whenToUseResolved[0].label }
    : allRelated[0]
      ? { href: allRelated[0].href, label: allRelated[0].label }
      : null;
const practicalLimit = sectionLimit();

const reviewerSchema = reviewConfig.reviewers.slice(0, 2).map((r) => ({
  '@type': 'Person',
  name: r.label.replace(/\s*\([^)]*\)\s*/g, '').trim(),
  url: new URL(r.href, siteUrl).toString(),
}));
const relatedMentions = allRelated.slice(0, 12).map((link) => ({
  '@type': 'WebPage',
  name: link.label,
  url: new URL(link.href, siteUrl).toString(),
}));
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((crumb, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.label,
    item: new URL(crumb.href, siteUrl).toString(),
  })),
};
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: config.h1,
  alternativeHeadline: config.discoverHeadline,
  description: config.description,
  abstract: quickAnswerText,
  articleSection: config.guideCategory ?? CATEGORY_LABEL?.[config.section] ?? 'Guides',
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  url: canonicalUrl,
  keywords: config.keywords,
  image: resolvedOgImageUrl ? [resolvedOgImageUrl] : undefined,
  primaryImageOfPage: resolvedOgImageUrl
    ? { '@type': 'ImageObject', url: resolvedOgImageUrl, width: 1200, height: 630 }
    : undefined,
  author: { '@type': 'Organization', name: 'Kefiw', url: new URL('/about/', siteUrl).toString() },
  publisher: {
    '@type': 'Organization',
    name: 'Kefiw',
    url: siteUrl.toString(),
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', siteUrl).toString() },
  },
  reviewedBy: reviewerSchema.length ? reviewerSchema : undefined,
  isPartOf: { '@type': 'WebSite', name: 'Kefiw', url: siteUrl.toString() },
  about: cluster
    ? { '@type': 'Thing', name: cluster.h1, url: new URL(clusterHref(cluster), siteUrl).toString() }
    : { '@type': 'Thing', name: config.guideCategory ?? CATEGORY_LABEL?.[config.section] ?? 'Guides' },
  mentions: relatedMentions.length ? relatedMentions : undefined,
};
const howToJsonLd = hasHowTo ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: config.h1,
  description: config.description,
  mainEntityOfPage: canonicalUrl,
  step: config.howTo!.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    text: step,
  })),
} : null;
const relatedItemListJsonLd = allRelated.length ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Related resources for ${config.h1}`,
  itemListElement: allRelated.slice(0, 12).map((link, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: new URL(link.href, siteUrl).toString(),
    name: link.label,
  })),
} : null;
---

<BaseLayout
  title={config.title}
  description={config.description}
  canonical={canonical}
  keywords={config.keywords}
  socialTitle={config.discoverHeadline}
  ogImage={resolvedOgImage}
  ogImageAlt={resolvedImageAlt}
  ogType="article"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(articleJsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {howToJsonLd && <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(howToJsonLd)} />}
  {relatedItemListJsonLd && <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(relatedItemListJsonLd)} />}
  <Breadcrumb crumbs={crumbs} />

  <article class={`container-wide py-6 ${isSop ? 'kfw-sop' : ''}`}>
    <header class="mb-6">
      {isSop ? (
        <div class="mb-2 text-[11px] font-mono uppercase tracking-[0.22em] text-cyan-700">▸ SOP · {config.guideCategory ?? 'Protocol'}</div>
      ) : null}
      <h1 class={isSop ? 'text-3xl font-bold tracking-tight sm:text-4xl font-mono text-slate-900' : 'text-3xl font-bold tracking-tight sm:text-4xl'}>{config.h1}</h1>
      {config.subhead && <p class={isSop ? 'mt-1 text-base font-mono text-slate-700' : 'mt-1 text-lg text-slate-700'}>{config.subhead}</p>}
      {config.outcomeLine && (
        <p class={isSop ? 'mt-1 text-xs font-mono uppercase tracking-widest text-cyan-700' : 'mt-1 text-sm font-medium text-brand-700'}>{config.outcomeLine}</p>
      )}
      <p class={isSop ? 'mt-2 max-w-3xl font-mono text-sm text-slate-700' : 'mt-2 max-w-3xl text-slate-600'}>
        <InlineMetric text={config.intro} specs={lmSpecs} />
      </p>
      {cluster && (
        <p class="mt-2 text-xs text-slate-500">
          Part of: <a href={clusterHref(cluster)} class="text-brand-700 hover:underline">{cluster.h1}</a>
        </p>
      )}
    </header>

    {resolvedHeroImage && (
      <figure class="mb-6 overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm">
        <img
          src={resolvedHeroImage}
          alt={resolvedImageAlt}
          width="1200"
          height="675"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="aspect-[16/9] w-full object-cover"
        />
      </figure>
    )}

    {isSop && hasFormula && (
      <section aria-label="Formula anchor" class="mb-6 rounded-lg border border-slate-300 bg-slate-50 p-4 font-mono">
        <div class="mb-2 text-[11px] uppercase tracking-[0.22em] text-cyan-700">▸ {config.formulaAnchor!.caption}</div>
        <pre class="overflow-x-auto whitespace-pre-wrap text-sm leading-relaxed text-slate-900">{config.formulaAnchor!.expression}</pre>
      </section>
    )}

    {isSop && hasGates && (
      <section aria-label="Logical gates" class="mb-8 rounded-lg border border-slate-300 bg-slate-50 p-4 font-mono text-sm text-slate-800">
        <div class="mb-2 text-[11px] uppercase tracking-[0.22em] text-amber-700">▸ Logical Gates</div>
        <ol class="list-decimal space-y-1 pl-6">
          {config.logicalGates!.map((g) => (
            <li><InlineMetric text={g} specs={lmSpecs} /></li>
          ))}
        </ol>
      </section>
    )}

    {showCtaRow && (
      <section aria-label="Quick actions" class="mb-6 flex flex-wrap gap-2">
        {config.primaryCta && (
          <a href={config.primaryCta.href} class="btn-primary">{config.primaryCta.label}</a>
        )}
        {secondaryCtas.map((c) => (
          <a href={c.href} class="btn-ghost">{c.label}</a>
        ))}
      </section>
    )}

    <div class="my-6">
      <AdSlot client:idle zoneId="ALPHA" />
    </div>

    {/*
      Compact trust strip. The full review-methodology links live at the
      bottom of the article, so this stays as a short credential signal.
    */}
    <aside aria-label="Review credential" class="mb-6 flex flex-wrap items-center gap-x-3 gap-y-1 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
      <span class="font-semibold uppercase tracking-[0.18em] text-slate-500">Built by</span>
      <a href={reviewConfig.builtBy.href} class="text-slate-700 hover:text-brand-700 hover:underline">{reviewConfig.builtBy.label}</a>
      <span aria-hidden="true" class="text-slate-300">·</span>
      <span class="font-semibold uppercase tracking-[0.18em] text-slate-500">Reviewed by</span>
      {reviewConfig.reviewers.slice(0, 2).map((r) => (
        <a href={r.href} class="text-slate-700 hover:text-brand-700 hover:underline">{r.label}</a>
      ))}
    </aside>

    {quickAnswerText && (
      <section aria-label="Quick answer" class="mb-8 rounded-lg border border-brand-200 bg-brand-50/70 p-4">
        <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-700">Quick answer</h2>
        <p class="mt-2 max-w-3xl text-sm text-slate-800">
          <InlineMetric text={quickAnswerText} specs={lmSpecs} />
        </p>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          {quickIntentText && (
            <div class="rounded-md border border-white/80 bg-white/70 p-3 text-xs text-slate-700">
              <div class="font-semibold text-slate-900">What you are trying to do</div>
              <div class="mt-1"><InlineMetric text={quickIntentText} specs={lmSpecs} /></div>
            </div>
          )}
          {bestNextStep && (
            <div class="rounded-md border border-white/80 bg-white/70 p-3 text-xs text-slate-700">
              <div class="font-semibold text-slate-900">Best next step</div>
              <a href={bestNextStep.href} class="mt-1 inline-block font-semibold text-brand-700 hover:underline">{bestNextStep.label}</a>
            </div>
          )}
          <div class="rounded-md border border-white/80 bg-white/70 p-3 text-xs text-slate-700">
            <div class="font-semibold text-slate-900">Limit to remember</div>
            <div class="mt-1">{practicalLimit}</div>
          </div>
        </div>
      </section>
    )}

    {hasKeyPoints && (
      <section aria-label="Key points" class="mb-8">
        <h2 class={isSop ? 'mb-3 text-xl font-mono uppercase tracking-wider text-slate-900' : 'mb-3 text-xl font-semibold'}>{isSop ? '▸ Key Specs' : 'Key points'}</h2>
        <ul class="space-y-2">
          {config.keyPoints!.map((pt) => (
            <li class={isSop ? 'flex gap-2 rounded-md border border-slate-300 bg-slate-50 p-3 font-mono text-sm text-slate-800' : 'flex gap-2 rounded-md border border-slate-200 bg-white p-3 text-sm'}>
              <span class={isSop ? 'mt-0.5 text-cyan-700' : 'mt-0.5 text-brand-600'}>▸</span>
              <span class={isSop ? '' : 'text-slate-800'}><InlineMetric text={pt} specs={lmSpecs} /></span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {hasHowTo && (
      <section aria-label="How to" class="mb-8">
        <h2 class={isSop ? 'mb-3 text-xl font-mono uppercase tracking-wider text-slate-900' : 'mb-3 text-xl font-semibold'}>{isSop ? '▸ Procedure' : 'How to'}</h2>
        <ol class={isSop ? 'list-decimal space-y-1 pl-6 font-mono text-sm text-slate-800' : 'list-decimal space-y-1 pl-6 text-sm text-slate-800'}>
          {config.howTo!.map((step) => <li><InlineMetric text={step} specs={lmSpecs} /></li>)}
        </ol>
      </section>
    )}

    {hasExamples && (
      <section aria-label="Examples" class="mb-8">
        <h2 class={isSop ? 'mb-3 text-xl font-mono uppercase tracking-wider text-slate-900' : 'mb-3 text-xl font-semibold'}>{isSop ? '▸ Worked Examples' : 'Examples'}</h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {config.examples!.map((ex) => (
            <li class={isSop ? 'rounded-md border border-slate-300 bg-slate-50 p-3 font-mono' : 'rounded-md border border-slate-200 bg-white p-3'}>
              <div class={isSop ? 'text-sm font-semibold text-cyan-700' : 'text-sm font-semibold text-slate-900'}>{ex.title}</div>
              <div class={isSop ? 'mt-1 text-sm text-slate-700' : 'mt-1 text-sm text-slate-700'}><InlineMetric text={ex.body} specs={lmSpecs} /></div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {hasWhenToUse && (
      <section aria-label="When to use which tool" class="mb-8">
        <h2 class="mb-3 text-xl font-semibold">When to use which tool</h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {whenToUseResolved.map(({ href, label, note, sub }) => (
            <li>
              <a href={href} class="block rounded-md border border-slate-200 bg-white p-3 hover:border-brand-500 hover:bg-brand-50">
                <div class="text-sm font-semibold text-slate-900">{label}</div>
                <div class="mt-1 text-sm text-slate-700">{note}</div>
                {sub && <div class="mt-1 text-xs text-slate-600">{sub}</div>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {hasLongform && (
      <section class="prose-tool max-w-3xl" aria-label="In depth">
        <Fragment set:html={longformHtml} />
      </section>
    )}

    {hasBody && (
      <section class="prose-tool max-w-3xl">
        <Fragment set:html={config.bodyHtml!} />
      </section>
    )}

    {hasThresholds && (
      <section aria-label="Operational thresholds" class="mb-8 rounded-lg border border-slate-300 bg-slate-50 p-4 font-mono text-sm text-slate-800">
        <div class="mb-3 text-xs uppercase tracking-widest text-slate-500">▸ Operational Thresholds</div>
        <ul class="space-y-2">
          <li class="flex gap-3">
            <span class="mt-0.5 inline-block h-2 w-2 flex-none rounded-full" style="background:#0891b2;"></span>
            <div><span class="font-bold text-cyan-700">CYAN · STABLE</span> — <span class="text-slate-700">{config.thresholds!.cyan}</span></div>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 inline-block h-2 w-2 flex-none rounded-full" style="background:#ca8a04;"></span>
            <div><span class="font-bold text-amber-700">GOLD · GUARDED</span> — <span class="text-slate-700">{config.thresholds!.gold}</span></div>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 inline-block h-2 w-2 flex-none rounded-full" style="background:#db2777;"></span>
            <div><span class="font-bold text-pink-700">MAGENTA · CRITICAL</span> — <span class="text-slate-700">{config.thresholds!.magenta}</span></div>
          </li>
        </ul>
      </section>
    )}

    {hasPivotSwitch ? (
      <section aria-label="Contextual pivot" class="mb-8">
        <PivotSwitch client:load critical={pvCritical!} stable={pvStable!} fallback={pvFallback!} />
      </section>
    ) : hasPivot && (
      <section aria-label="Pivot" class="mb-8">
        <a href={toolHref(pivotTool!)} class="block rounded-lg border border-brand-500 bg-brand-50 p-4 no-underline hover:border-brand-700 hover:bg-brand-100">
          <div class="text-xs uppercase tracking-widest text-brand-700">▸ Pivot</div>
          <div class="mt-1 text-sm text-slate-700">{config.pivotLink!.note}</div>
          <div class="mt-2 text-base font-semibold text-brand-700">{pivotTool!.h1} →</div>
        </a>
      </section>
    )}

    <div class="my-6">
      <AdSlot client:idle zoneId="GAMMA" />
    </div>

    {allRelated.length > 0 && (
      <section aria-label="Related" class="mt-10">
        <h2 class="mb-3 text-xl font-semibold">Related</h2>
        <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
          {allRelated.map((link) => (
            <li>
              <a href={link.href} class="block rounded-md border border-slate-200 p-3 hover:border-brand-500 hover:bg-brand-50">
                <div class="text-sm font-semibold text-slate-900">{link.label}</div>
                {link.sub && <div class="mt-0.5 text-xs text-slate-600">{link.sub}</div>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {hasFaq && <FAQ items={config.faq} />}

    <div class="my-6">
      <AdSlot client:idle zoneId="EPSILON" />
    </div>

    <ReviewMethodologyFooter reviewerLinks={reviewApprovalLinks} includeHealthDisclaimer={usesHealthReview} />

    <div class="my-6">
      <AdSlot client:idle zoneId="DELTA" format="multiplex" />
    </div>
  </article>
</BaseLayout>

