---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import FAQ from '~/components/FAQ.astro';
import RelatedTools from '~/components/RelatedTools.astro';
import StartHere from '~/components/StartHere.astro';
import ToolTips from '~/components/ToolTips.astro';
import FollowUpTools from '~/components/FollowUpTools.astro';
import AdSlot from '~/components/ads/AdSlot.tsx';
import ReviewMethodologyFooter from '~/components/ReviewMethodologyFooter.astro';
import { reviewPanelForArea } from '~/data/review';
import type { ToolConfig } from '~/data/tools';
import { CATEGORIES, toolHref } from '~/data/tools';
import { CLUSTERS_BY_SLUG, clusterHref } from '~/data/clusters';

interface Props { tool: ToolConfig; }
const { tool } = Astro.props;
const cat = CATEGORIES[tool.category];
const cluster = tool.clusterId ? CLUSTERS_BY_SLUG[tool.clusterId] : undefined;
const reviewConfig = reviewPanelForArea(tool.category);
const usesHealthReview = reviewConfig.reviewers.some((reviewer) => reviewer.href === '/registered-nurse-review/');
const reviewApprovalLinks = usesHealthReview
  ? [
      { label: 'registered nurse', href: '/registered-nurse-review/' },
      { label: 'scientific reviewer', href: '/scientific-review/' },
    ]
  : undefined;
const crumbs = [
  { href: '/', label: 'Home' },
  { href: `/${cat.slug}/`, label: cat.title },
  { href: toolHref(tool), label: tool.h1 },
];

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: tool.h1,
  description: tool.description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  url: new URL(toolHref(tool), Astro.site).toString(),
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const numericToolIds = new Set([
  'average-calculator',
  'percentage-calculator',
  'percent-of-calculator',
  'percent-change-calculator',
  'ratio-calculator',
  'fraction-calculator',
  'hours-calculator',
  'discount-calculator',
  'tip-calculator',
  'markup-margin-calculator',
  'break-even-calculator',
  'mortgage-calculator',
  'mortgage-extra-payment-calculator',
  'markup-calculator',
  'margin-calculator',
  'savings-goal-calculator',
]);

const cueText =
  tool.id === 'average-calculator'
      ? 'Enter numbers below'
      : numericToolIds.has(tool.id)
        ? 'Enter values below'
        : tool.category === 'word-tools'
          ? 'Enter letters or text below'
          : tool.category === 'converters'
            ? 'Enter a value below'
            : 'Start below';
const cueHelp = 'Scroll up for overview, down for guides';
---
<BaseLayout
  title={tool.title}
  description={tool.description}
  canonical={toolHref(tool)}
  keywords={tool.keywords}
  noindex={tool.comingSoon === true || tool.noindex === true}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(webAppJsonLd)} />
  <Breadcrumb crumbs={crumbs} />
  <article class="container-wide py-6">
    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{tool.h1}</h1>
      {tool.outcomeLine && <p class="mt-1 max-w-3xl text-base font-medium text-slate-700">{tool.outcomeLine}</p>}
      <p class="mt-2 max-w-3xl text-slate-600">{tool.intro}</p>
      {cluster && (
        <p class="mt-2 text-xs text-slate-500">
          Part of: <a href={clusterHref(cluster)} class="text-brand-700 hover:underline">{cluster.h1}</a>
        </p>
      )}
      <StartHere tool={tool} />
    </header>

    {/*
      Compact trust strip. The full review-methodology links live at the
      bottom of the page, so this stays as a short credential signal.
    */}
    <aside aria-label="Review credential" class="mb-6 flex flex-wrap items-center gap-x-3 gap-y-1 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
      <span class="font-semibold uppercase tracking-[0.18em] text-slate-500">Built by</span>
      <a href={reviewConfig.builtBy.href} class="text-slate-700 hover:text-brand-700 hover:underline">{reviewConfig.builtBy.label}</a>
      <span aria-hidden="true" class="text-slate-300">·</span>
      <span class="font-semibold uppercase tracking-[0.18em] text-slate-500">Reviewed by</span>
      {reviewConfig.reviewers.slice(0, 2).map((r) => (
        <a href={r.href} class="text-slate-700 hover:text-brand-700 hover:underline">{r.label}</a>
      ))}
    </aside>

    <div class="my-6">
      <AdSlot client:idle zoneId="ALPHA" />
    </div>

    <section
      id="tool-start"
      aria-label="Tool"
      class="mb-8"
      data-tool-state-key={tool.category === 'calculators' ? `kfw_tool_state:${tool.id}` : undefined}
    >
      {tool.category === 'games' ? (
        <div class="flex h-2.5 items-center gap-2 overflow-hidden text-[9px] uppercase leading-none tracking-[0.10em] text-slate-500">
          <span class="h-px flex-1 bg-slate-200" aria-hidden="true"></span>
          <span class="whitespace-nowrap">{cueHelp}</span>
          <span class="h-px flex-1 bg-slate-200" aria-hidden="true"></span>
        </div>
      ) : (
        <div class="mb-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center uppercase text-slate-500">
          <div class="flex items-center gap-3 text-[11px] tracking-[0.16em]">
            <span class="h-px flex-1 bg-slate-200" aria-hidden="true"></span>
            <span class="whitespace-nowrap font-semibold text-slate-700">{cueText}</span>
            <span class="h-px flex-1 bg-slate-200" aria-hidden="true"></span>
          </div>
          <div class="mt-1 text-[10px] tracking-[0.12em]">
            {cueHelp}
          </div>
        </div>
      )}
      <slot />
    </section>

    <div class="my-6">
      <AdSlot client:idle zoneId="GAMMA" />
    </div>

    <section class="prose-tool max-w-3xl">
      <h2>How to use</h2>
      <ol class="my-3 list-decimal pl-6 text-slate-700">
        {tool.howTo.map((step) => <li>{step}</li>)}
      </ol>

      <h2>Examples</h2>
      {tool.examples.map((ex) => (
        <div class="mb-3 rounded-md border border-slate-200 bg-slate-50 p-3">
          <div class="text-sm font-semibold text-slate-900">{ex.title}</div>
          <div class="text-sm text-slate-700">{ex.body}</div>
        </div>
      ))}
    </section>

    {(tool.useCases ?? []).length > 0 && (
      <section aria-label="Use cases" class="mt-8 max-w-3xl">
        <h2 class="mb-3 text-xl font-semibold">What users are actually trying to do</h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {tool.useCases!.map((uc) => (
            <li class="flex gap-2 rounded-md border border-slate-200 bg-white p-3 text-sm text-slate-800">
              <span class="mt-0.5 text-brand-600">▸</span>
              <span>{uc}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {(tool.commonMistakes ?? []).length > 0 && (
      <section aria-label="Common mistakes" class="mt-8 max-w-3xl">
        <h2 class="mb-3 text-xl font-semibold">Common mistakes</h2>
        <ul class="space-y-2">
          {tool.commonMistakes!.map((m) => (
            <li class="flex gap-2 rounded-md border border-amber-200 bg-amber-50 p-3 text-sm text-slate-800">
              <span class="mt-0.5 text-amber-700">!</span>
              <span>{m}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {(tool.limitations ?? []).length > 0 && (
      <section aria-label="Limitations" class="mt-8 max-w-3xl">
        <h2 class="mb-3 text-xl font-semibold">Limitations</h2>
        <ul class="space-y-2">
          {tool.limitations!.map((lim) => (
            <li class="flex gap-2 rounded-md border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <span class="mt-0.5 text-slate-500">·</span>
              <span>{lim}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="my-6">
      <AdSlot client:idle zoneId="EPSILON" />
    </div>

    <FollowUpTools tool={tool} />
    <FAQ items={tool.faq} />
    <ToolTips tool={tool} />

    <div class="my-6">
      <AdSlot client:idle zoneId="ZETA" />
    </div>

    <RelatedTools tool={tool} />

    <ReviewMethodologyFooter reviewerLinks={reviewApprovalLinks} includeHealthDisclaimer={usesHealthReview} />

    <div class="my-6">
      <AdSlot client:idle zoneId="DELTA" format="multiplex" />
    </div>
  </article>
  <script is:inline>
    (() => {
      if (window.location.hash) return;
      const target = document.getElementById('tool-start');
      if (!target) return;
      const scrollToTool = () => {
        const header = document.querySelector('header.sticky, body > header, header');
        const headerHeight = header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
        const top = target.getBoundingClientRect().top + window.scrollY - headerHeight - 8;
        window.scrollTo({ top: Math.max(0, top), behavior: 'auto' });
      };
      requestAnimationFrame(scrollToTool);
      window.setTimeout(scrollToTool, 350);
      window.setTimeout(scrollToTool, 900);
    })();
  </script>
  <script is:inline>
    (() => {
      const root = document.getElementById('tool-start');
      const key = root?.dataset.toolStateKey;
      if (!root || !key) return;

      const selector = 'input, textarea, select';
      const eventOptions = { bubbles: true };

      const elementKey = (el, index) => {
        const id = el.getAttribute('id');
        const name = el.getAttribute('name');
        return `${el.tagName.toLowerCase()}:${id || name || index}`;
      };

      const controls = () => Array.from(root.querySelectorAll(selector))
        .filter((el) => {
          if (el.disabled) return false;
          if (el instanceof HTMLInputElement) {
            return !['button', 'submit', 'reset', 'file', 'password'].includes(el.type);
          }
          return true;
        });

      const readState = () => {
        const state = {};
        controls().forEach((el, index) => {
          const id = elementKey(el, index);
          if (el instanceof HTMLInputElement && (el.type === 'checkbox' || el.type === 'radio')) {
            state[id] = { checked: el.checked };
            return;
          }
          state[id] = { value: el.value };
        });
        return state;
      };

      const applyValue = (el, value) => {
        const proto = el instanceof HTMLTextAreaElement
          ? HTMLTextAreaElement.prototype
          : el instanceof HTMLSelectElement
            ? HTMLSelectElement.prototype
            : HTMLInputElement.prototype;
        const setter = Object.getOwnPropertyDescriptor(proto, 'value')?.set;
        if (setter) setter.call(el, value);
        else el.value = value;
      };

      const restoreState = () => {
        let saved;
        try {
          saved = JSON.parse(localStorage.getItem(key) || '{}');
        } catch {
          saved = {};
        }
        if (!saved || typeof saved !== 'object') return;

        controls().forEach((el, index) => {
          const item = saved[elementKey(el, index)];
          if (!item) return;
          if (el instanceof HTMLInputElement && (el.type === 'checkbox' || el.type === 'radio')) {
            el.checked = !!item.checked;
            el.dispatchEvent(new Event('change', eventOptions));
            el.dispatchEvent(new Event('input', eventOptions));
            return;
          }
          if ('value' in item) {
            applyValue(el, String(item.value ?? ''));
            el.dispatchEvent(new Event('input', eventOptions));
            el.dispatchEvent(new Event('change', eventOptions));
          }
        });
      };

      let saveTimer = 0;
      const scheduleSave = () => {
        window.clearTimeout(saveTimer);
        saveTimer = window.setTimeout(() => {
          try {
            localStorage.setItem(key, JSON.stringify(readState()));
          } catch {
            /* storage unavailable */
          }
        }, 120);
      };

      root.addEventListener('input', scheduleSave);
      root.addEventListener('change', scheduleSave);
      requestAnimationFrame(restoreState);
      window.setTimeout(restoreState, 400);
      window.setTimeout(restoreState, 900);
    })();
  </script>
</BaseLayout>
