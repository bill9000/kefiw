---
import ToolSearch from './ToolSearch.tsx';
---
<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="container-wide flex h-14 items-center gap-3">
    <a href="/" class="flex items-center gap-2 font-bold text-slate-900 no-underline" aria-label="Kefiw home">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded bg-brand-600 text-sm font-bold text-white">K</span>
      <span>Kefiw</span>
    </a>
    <nav class="ml-4 hidden gap-4 text-sm text-slate-700 sm:flex" aria-label="Primary">
      <a href="/word-tools/" class="hover:text-brand-700">Word Tools</a>
      <a href="/converters/" class="hover:text-brand-700">Converters</a>
      <a href="/calculators/" class="hover:text-brand-700">Calculators</a>
      <a href="/decisions/" class="hover:text-brand-700">Decisions</a>
      <a href="/health/" class="hover:text-brand-700">Health</a>
      <a href="/logic/" class="hover:text-brand-700">Logic</a>
      <a href="/games/" class="hover:text-brand-700">Games</a>
      <a href="/guides/" class="hover:text-brand-700">Guides</a>
    </nav>
    <div class="ml-auto w-full max-w-[12rem] sm:max-w-xs">
      <ToolSearch client:idle />
    </div>
  </div>
  <nav class="container-wide flex gap-2 overflow-x-auto pb-2 text-xs sm:hidden" aria-label="Mobile categories">
    <a href="/word-tools/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Word Tools</a>
    <a href="/converters/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Converters</a>
    <a href="/calculators/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Calculators</a>
    <a href="/decisions/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Decisions</a>
    <a href="/health/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Health</a>
    <a href="/logic/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Logic</a>
    <a href="/games/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Games</a>
    <a href="/guides/" class="whitespace-nowrap rounded-full bg-slate-100 px-3 py-1.5 text-slate-700 no-underline hover:bg-slate-200">Guides</a>
  </nav>
</header>
