---
interface Props {
  compact?: boolean;
  showIntro?: boolean;
  class?: string;
}

const {
  compact = false,
  showIntro = true,
  class: className = '',
} = Astro.props;

const signals = [
  {
    label: 'HTTPS production',
    href: '/trust/',
    detail: 'Production pages are served over HTTPS; the browser address bar is the source of truth.',
  },
  {
    label: 'IAB ad consent',
    href: '/privacy/',
    detail: 'Google AdSense Privacy & Messaging handles required advertising consent flows.',
  },
  {
    label: 'Source-linked methods',
    href: '/methodology/',
    detail: 'Calculators and guides expose formulas, assumptions, limits, and source families.',
  },
  {
    label: 'Staff review lanes',
    href: '/about-the-reviewers/',
    detail: 'Reviewer pages define engineering, scientific, nurse, contractor, and realtor scope.',
  },
  {
    label: 'Corrections process',
    href: '/corrections/',
    detail: 'Users can report errors, stale assumptions, and confusing explanations.',
  },
  {
    label: 'Ads disclosed',
    href: '/advertising-disclosure/',
    detail: 'Advertising and monetization boundaries are documented separately.',
  },
];
---

<div
  aria-label="Trust signals"
  class:list={[
    compact
      ? 'text-xs text-slate-600'
      : 'rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-700',
    className,
  ]}
>
  {showIntro && (
    <p class={compact ? 'mb-2 font-medium text-slate-700' : 'mb-3 font-medium text-slate-800'}>
      Trust signals are linked to the standards Kefiw actually maintains.
    </p>
  )}
  <div class="flex flex-wrap gap-2">
    {signals.map((signal) => (
      <a
        href={signal.href}
        title={signal.detail}
        class:list={[
          'inline-flex items-center rounded-full border font-semibold transition hover:border-brand-500 hover:text-brand-700',
          compact
            ? 'border-slate-200 bg-white px-2.5 py-1 text-[11px] text-slate-700'
            : 'border-slate-200 bg-slate-50 px-3 py-1.5 text-xs text-slate-700',
        ]}
      >
        {signal.label}
      </a>
    ))}
  </div>
</div>
