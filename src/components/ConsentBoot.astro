---
// ConsentBoot — inline head script that registers __tcfapi (TCF 2.3) and
// __gppapi (GPP 1.1) STUBS synchronously so AdSense / third parties find
// them on first query. The stubs buffer calls; src/lib/consent.ts drains
// the queue when the full CMP state machine boots.
//
// Must be injected BEFORE <AdSenseScript />.
---
<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;

    // TCF 2.2 stub — queues calls until real impl registers.
    if (!window.__tcfapi) {
      var tcfQueue = [];
      window.__tcfapi = function (command, version, callback, parameter) {
        tcfQueue.push({ command: command, version: version, callback: callback, parameter: parameter });
        if (command === 'ping') {
          callback(
            {
              cmpLoaded: false,
              cmpStatus: 'stub',
              displayStatus: 'hidden',
              apiVersion: '2.3',
              cmpVersion: 1,
              cmpId: 0,
              gvlVersion: 3,
              tcfPolicyVersion: 5,
            },
            true
          );
        }
      };
      window.__tcfapi.queue = tcfQueue;

      try {
        if (!window.frames['__tcfapiLocator']) {
          var iframe = document.createElement('iframe');
          iframe.style.cssText = 'display:none;position:absolute;width:0;height:0;border:0';
          iframe.name = '__tcfapiLocator';
          (document.body || document.documentElement).appendChild(iframe);
        }
      } catch (e) {
        /* body not ready — real init re-tries */
      }
    }

    // GPP 1.1 stub — queues calls until real impl registers.
    if (!window.__gppapi) {
      var gppQueue = [];
      window.__gppapi = function (command, callback, parameter) {
        gppQueue.push({ command: command, callback: callback, parameter: parameter });
        if (command === 'ping') {
          callback(
            {
              gppVersion: '1.1',
              cmpStatus: 'stub',
              cmpDisplayStatus: 'hidden',
              signalStatus: 'not ready',
              supportedAPIs: [],
              cmpId: 0,
              sectionList: [],
              applicableSections: [],
              gppString: '',
              parsedSections: {},
            },
            true
          );
        }
      };
      window.__gppapi.queue = gppQueue;
    }
  })();
</script>
