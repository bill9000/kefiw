---
interface Props {
  title: string;
  trains: string;
  scoring: string;
  routine: string;
  href: string;
  linkLabel: string;
}

const { title, trains, scoring, routine, href, linkLabel } = Astro.props;
---

<section class="mx-auto mt-8 max-w-3xl rounded-lg border border-slate-200 bg-white p-5">
  <h2 class="text-xl font-semibold text-slate-900">Why {title} is in Kefiw Daily</h2>
  <div class="mt-3 grid gap-4 text-sm leading-6 text-slate-700 md:grid-cols-2">
    <div>
      <h3 class="font-semibold text-slate-900">What it trains</h3>
      <p class="mt-1">{trains}</p>
    </div>
    <div>
      <h3 class="font-semibold text-slate-900">How scoring works</h3>
      <p class="mt-1">{scoring}</p>
    </div>
    <div>
      <h3 class="font-semibold text-slate-900">How to use it</h3>
      <p class="mt-1">{routine}</p>
    </div>
    <div>
      <h3 class="font-semibold text-slate-900">Privacy and review</h3>
      <p class="mt-1">
        Round state stays in local browser storage unless you choose to post a score.
        Use <a href={href} class="text-brand-700 underline">{linkLabel}</a> after the round to review the underlying tool or practice family.
      </p>
    </div>
  </div>
</section>
