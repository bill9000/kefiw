---
import type { FaqItem } from '~/data/tools';
interface Props { items: FaqItem[]; }
const { items } = Astro.props;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<section class="container-wide mt-10">
  <h2 class="mb-3 text-xl font-semibold">Frequently asked questions</h2>
  <div class="divide-y divide-slate-200 rounded-lg border border-slate-200 bg-white">
    {items.map((f) => (
      <details class="group p-4">
        <summary class="cursor-pointer list-none font-medium text-slate-900 marker:hidden">
          <span class="inline-block w-5 text-brand-600 transition group-open:rotate-90">›</span>
          {f.q}
        </summary>
        <p class="mt-2 pl-5 text-slate-700">{f.a}</p>
      </details>
    ))}
  </div>
</section>
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
