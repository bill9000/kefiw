---
import type { FaqItem } from '~/data/tools';
interface Props { items: FaqItem[]; }
const { items } = Astro.props;

function inferIntent(f: FaqItem): string | undefined {
  if (f.faq_intent) return f.faq_intent;
  const q = f.q.toLowerCase();
  if (q.startsWith('what is') || q.startsWith('what are')) return 'definition';
  if (q.includes(' vs ') || q.includes('versus') || q.includes('difference') || q.includes('better')) return 'comparison';
  if (q.includes('why') || q.includes('wrong') || q.includes('stuck') || q.includes('not working')) return 'troubleshooting';
  if (q.startsWith('how') || q.startsWith('when')) return 'how-to';
  if (q.startsWith('is') || q.startsWith('can') || q.startsWith('should')) return 'trust';
  return undefined;
}

const itemsWithIntent = items.map((item) => ({
  ...item,
  faq_intent: inferIntent(item),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: itemsWithIntent.map((f) => {
    const question: Record<string, unknown> = {
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    };
    if (f.faq_intent) {
      question.additionalProperty = {
        '@type': 'PropertyValue',
        name: 'faqIntent',
        value: f.faq_intent,
      };
    }
    return question;
  }),
};
const intentLabel: Record<string, string> = {
  definition: 'Definition',
  comparison: 'Comparison',
  'edge-case': 'Edge case',
  'how-to': 'How-to',
  troubleshooting: 'Troubleshooting',
  cost: 'Cost',
  trust: 'Trust & accuracy',
};
---
<section class="container-wide mt-10">
  <h2 class="mb-3 text-xl font-semibold">Frequently asked questions</h2>
  <div class="divide-y divide-slate-200 rounded-lg border border-slate-200 bg-white">
    {itemsWithIntent.map((f) => (
      <details class="group p-4" data-faq-intent={f.faq_intent ?? undefined}>
        <summary class="cursor-pointer list-none font-medium text-slate-900 marker:hidden">
          <span class="inline-block w-5 text-brand-600 transition group-open:rotate-90">›</span>
          {f.q}
          {f.faq_intent && (
            <span class="ml-2 inline-block rounded bg-slate-100 px-1.5 py-0.5 align-middle text-[10px] font-normal uppercase tracking-wide text-slate-600">
              {intentLabel[f.faq_intent] ?? f.faq_intent}
            </span>
          )}
        </summary>
        <p class="mt-2 pl-5 text-slate-700">{f.a}</p>
      </details>
    ))}
  </div>
</section>
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
