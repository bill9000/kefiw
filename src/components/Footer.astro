---
import { execSync } from 'node:child_process';

const year = new Date().getFullYear();

function gitInfo() {
  const envSha = process.env.CF_PAGES_COMMIT_SHA;
  try {
    const sha = execSync('git rev-parse --short HEAD').toString().trim();
    const date = execSync('git log -1 --format=%cs').toString().trim();
    return { sha, date };
  } catch {
    return { sha: envSha ? envSha.slice(0, 7) : 'dev', date: '' };
  }
}
const { sha, date } = gitInfo();
---
<footer class="mt-16 border-t border-slate-200 bg-slate-50">
  <div class="container-wide py-10 text-sm text-slate-600">
    <div class="mb-6 grid gap-4 sm:grid-cols-3">
      <a href="/chains/" class="block rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:bg-cyan-50">
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Chains</div>
        <div class="mt-0.5 text-sm font-semibold text-slate-900">The Deterministic Engine</div>
        <div class="mt-0.5 text-xs text-slate-600">Pipelines that wire calculators into one live variable stream.</div>
      </a>
      <a href="/comparisons/" class="block rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:bg-cyan-50">
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Comparisons</div>
        <div class="mt-0.5 text-sm font-semibold text-slate-900">The Matrix Primitive</div>
        <div class="mt-0.5 text-xs text-slate-600">Two scenarios, one form, a live delta bar picks a winner.</div>
      </a>
      <a href="/scenarios/" class="block rounded-md border border-cyan-200 bg-white p-3 transition hover:border-cyan-500 hover:bg-cyan-50">
        <div class="text-[10px] font-semibold uppercase tracking-[0.2em] text-cyan-600">Scenarios</div>
        <div class="mt-0.5 text-sm font-semibold text-slate-900">The Triad Primitive</div>
        <div class="mt-0.5 text-xs text-slate-600">Three parallel pillars — Baseline, Optimized, Crisis.</div>
      </a>
    </div>
    <p class="mb-4 max-w-2xl text-xs text-slate-500">
      Kefiw is a short, memorable name for a site built around quick wins: word tools, calculators, decision tools, and daily challenges.
    </p>
    <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
      <div>© {year} Kefiw. Built static-first.</div>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/about-the-reviewers/">About the Reviewers</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/methodology/">Methodology</a>
        <a href="/sources/">Sources</a>
        <a href="/health-disclaimer/">Health Disclaimer</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
      </div>
    </div>
    <p class="mt-4 text-xs text-slate-500">
      Kefiw is not affiliated with Hasbro, Mattel, Zynga, or Collins. Scrabble and Words With Friends are trademarks of their respective owners.
    </p>
    <p class="mt-2 font-mono text-[11px] text-slate-400">
      build {sha}{date && <span> · {date}</span>}
    </p>
  </div>
</footer>
