---
import type { ReviewPanelConfig } from '~/data/review';

interface Props {
  config: ReviewPanelConfig;
}

const { config } = Astro.props;
---

<section aria-label="Review and methodology" class="mt-8 max-w-4xl rounded-xl border border-slate-200 bg-slate-50 p-5">
  <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Review & methodology</div>
  <h2 class="mt-2 text-xl font-semibold text-slate-900">How this page is reviewed</h2>
  <p class="mt-2 max-w-3xl text-sm text-slate-700">{config.intro}</p>

  <div class="mt-5 grid gap-3 lg:grid-cols-3">
    <article class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Built by</div>
      <a href={config.builtBy.href} class="mt-1 block text-sm font-semibold text-brand-700 hover:underline">{config.builtBy.label}</a>
      <p class="mt-1 text-sm text-slate-700">{config.builtBy.note}</p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-4 lg:col-span-2">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Reviewed by</div>
      <ul class="mt-2 grid gap-3 sm:grid-cols-2">
        {config.reviewers.map((reviewer) => (
          <li class="rounded-md border border-slate-200 bg-slate-50 p-3">
            <a href={reviewer.href} class="text-sm font-semibold text-brand-700 hover:underline">{reviewer.label}</a>
            <p class="mt-1 text-sm text-slate-700">{reviewer.note}</p>
          </li>
        ))}
      </ul>
    </article>
  </div>

  <div class="mt-5 grid gap-4 lg:grid-cols-[1.6fr_1fr]">
    <article class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">What the review covers</div>
      <ul class="mt-2 space-y-2 text-sm text-slate-700">
        {config.scope.map((item) => (
          <li class="flex gap-2">
            <span class="mt-0.5 text-brand-600">▸</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>

    <article class="rounded-lg border border-amber-200 bg-amber-50 p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-amber-800">Limits</div>
      <p class="mt-2 text-sm text-slate-800">{config.caution}</p>
    </article>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    {config.links.map((link) => (
      <a href={link.href} class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 no-underline transition hover:border-brand-500 hover:text-brand-700">
        {link.label}
      </a>
    ))}
  </div>
</section>
